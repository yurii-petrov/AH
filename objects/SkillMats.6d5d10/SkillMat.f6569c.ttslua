serpent = require("util/serpent")

-- код для карти з дебафом
function debuff(player, alt, id)
	local debuff_icon
	local debuff_color = self.UI.getAttribute(id, 'textColor')
	if id == "debuff_lore" then
		debuff_icon = ''
	elseif id == "debuff_influence" then
		debuff_icon = ''
	elseif id == "debuff_observatione" then
		debuff_icon = ''
	elseif id == "debuff_strength" then
		debuff_icon = ''
	elseif id == "debuff_will" then
		debuff_icon = ''
	end
	self.UI.setAttribute('debuff_icon', 'text', debuff_icon)
	self.UI.setAttribute('debuff_icon', 'color', debuff_color)
	self.UI.setAttribute('debuff_buttons', 'active', 'false')
	self.UI.setAttribute('debuff_display', 'active', 'true')
end
function debuff_return(player, alt, id)
	self.UI.setAttribute('debuff_buttons', 'active', 'true')
	self.UI.setAttribute('debuff_display', 'active', 'false')
end
-- кінець коду для карти з дебафом

local DEBUFF_ICONS = {
	{ id = "debuff_lore",         icon = "",  textColor = "#805d9b", position = "-440 -40 0" },
	{ id = "debuff_influence",    icon = "",  textColor = "#ff6f38", position = "-210 -40 0" },
	{ id = "debuff_observatione", icon = "",  textColor = "#467e42", position = "50 -40 0"   },
	{ id = "debuff_strength",     icon = "",  textColor = "#da4d38", position = "280 -40 0"  },
	{ id = "debuff_will",         icon = "",  textColor = "#667db6", position = "460 -40 0"  },
}

local function makeDebuffButton(def)
	return {
		tag = "button",
		attributes = {
			id = def.id,
			onClick = "debuff",
			width = "200",
			height = "280",
			position = def.position,
			fontSize = "150",
			font = "Fonts/AHRDIcons",
			textColor = def.textColor,
			color = "clear",
			text = "",
		}
	}
end

local function makeCounterPanel(id, active, position, onClick, textColor, padding, text, txtId, txtPosition, txtLabel)
	return {
		tag = "panel",
		attributes = { id = id, active = active, width = "500", height = "300", scale = "0.1 0.1 0", position = position, rotation = "0 0 180" },
		children = {
			{ tag = "button", attributes = {
					id = id .. "_btn",
					onClick = onClick,
					width = "500",
					height = "300",
					position = "0 -40 0",
					padding = padding,
					fontSize = "290",
					fontStyle = "Bold",
					font = "Fonts/AdonisC",
					textColor = textColor,
					color = "clear",
					text = text,
				}
			},
			{ tag = "text", attributes = {
					id = txtId,
					position = txtPosition,
					fontSize = "70",
					fontStyle = "Bold",
					font = "Fonts/AdonisC",
					color = "#fff5e2",
					text = txtLabel,
				}
			},
		}
	}
end

local function makeClsPanel(id, position, padding)
	return {
		tag = "panel",
		attributes = { id = id, active = "false", width = "500", height = "300", scale = "0.1 0.1 0", position = position, rotation = "0 0 180" },
		children = {
			{ tag = "button", attributes = {
					onClick = "ItemMatDestruct",
					width = "500",
					height = "300",
					position = "0 -40 0",
					padding = padding,
					fontSize = "290",
					fontStyle = "Bold",
					font = "Fonts/AdonisC",
					textColor = "#e9543b",
					color = "clear",
					text = "X",
				}
			},
		}
	}
end

local function buildUI()
	local debuffButtons = {}
	for _, def in ipairs(DEBUFF_ICONS) do
		table.insert(debuffButtons, makeDebuffButton(def))
	end

	local xml = {
		{
			tag = "panel",
			attributes = { id = "debuff_buttons", active = "true", width = "1200", height = "280", scale = "0.1 0.1 0", position = "0 82 -11", rotation = "0 0 180" },
			children = debuffButtons,
		},
		{
			tag = "panel",
			attributes = { id = "debuff_display", active = "false", width = "1200", height = "280", scale = "0.1 0.1 0", position = "0 82 -11", rotation = "0 0 180" },
			children = {
				{ tag = "button", attributes = { id = "debuff_return", onClick = "debuff_return", width = "1000", height = "280", position = "0 -40 0", color = "clear", text = "" } },
				{ tag = "text", attributes = { position = "-400 -30 0", fontSize = "220", fontStyle = "Bold", font = "Fonts/AdonisC", color = "#fff5e2", text = "-1" } },
				{ tag = "text", attributes = { id = "debuff_icon", position = "300 -45 0", fontSize = "280", font = "Fonts/AHRDIcons", color = "#805d9b", text = "" } },
			}
		},
		makeCounterPanel("damage", "false", "30 85 -11", "damage", "#e9543b", "0 300 10 0", "0", "damage_txt", "150 78 0", "ПОРАНЕННЯ"),
		makeClsPanel("damage_cls", "30 85 -11", "0 300 10 0"),
		makeCounterPanel("horror", "false", "-30 85 -11", "horror", "#485cb3", "300 0 10 0", "0", "horror_txt", "-26 -93 -11", "ЖАХ"),
		makeClsPanel("horror_cls", "-30 85 -11", "300 0 10 0"),
	}
	self.UI.setXmlTable(xml)
end

local data = {
	hp = 0,
	maxHp = nil, -- вписав руками для тесту
	sp = 0,
	maxSp = nil, -- вписав руками для тесту
  }

-- це все не працювало
  function onLoad(savedData)
	local sData = parseJson(savedData)
	print(serpent.tts(sData))
	if sData then
	  data = sData
	end


	buildUI()
	Wait.frames(prepareTile, 1)
  end

  function onSave()
	local saveData = JSON.encode(data)
	return saveData
  end

function prepareTile() -- запустити під час аттачу щоб видалити зайвий каунтер
	self.UI.setAttribute('damage', 'active', data.maxHp ~= nil) 
	self.UI.setAttribute('horror', 'active', data.maxSp ~= nil) 
end

function damage(player, alt_click, id) -- обробка кліка по HP
	if alt_click == "-1" then
		if data.maxHp and data.hp < data.maxHp then data.hp = data.hp + 1 end
	elseif alt_click == "-2" then
		if data.hp > 0 then data.hp = data.hp - 1 end
	end
	updateTile()
end

function horror(player, alt_click, id) -- обробка кліка по SP
	if alt_click == "-1" then
		if data.maxSp and data.sp < data.maxSp then data.sp = data.sp + 1 end
	elseif alt_click == "-2" then
		if data.sp > 0 then data.sp = data.sp - 1 end
	end
	updateTile()
end

function setData(d)
	data.hp = 0
	data.sp = 0
	data.maxHp = d.hp
	data.maxSp = d.sp
	data.unbreakable = d.unbreakable
	prepareTile()
end

function updateTile() -- оновлення XML
	local colorDamage = self.UI.getAttribute('damage_btn', 'textColor')
	local colorHorror = self.UI.getAttribute('horror_btn', 'textColor')
	if data.hp == data.maxHp then
		self.UI.setAttribute('horror', 'active', false)
		self.UI.setAttribute('horror_cls', 'active', true)
	else
		self.UI.setAttribute('horror', 'active', true)
		self.UI.setAttribute('horror_cls', 'active', false)
	end
	if data.sp == data.maxSp then
		self.UI.setAttribute('damage', 'active', false)
		self.UI.setAttribute('damage_cls', 'active', true)
	else
		self.UI.setAttribute('damage', 'active', true)
		self.UI.setAttribute('damage_cls', 'active', false)
	end
	self.UI.setAttribute('damage_btn', 'text', data.hp)
	self.UI.setAttribute('horror_btn', 'text', data.sp)
	self.UI.setAttribute('damage_btn', 'textColor', colorDamage)
	self.UI.setAttribute('horror_btn', 'textColor', colorHorror)
end

function ItemMatDestruct() -- обробка кліку по Х
	Global.call("onItemMatDestruct", self)
end

function parseJson(memo)
  if not memo or type(memo) ~= "string" then
    return nil
  end

  local success, result = pcall(function()
    return JSON.decode(memo)
  end)

  if success then
    return result
  else
    return nil
  end
end
