<panel
	id="chooseAddons"
	active="false"
	height="700"
	width="1000"
	position="0 0"
	rectAlignment="MiddleCenter"
	allowDragging="true"
	returnToOriginalPositionWhenReleased="false">
	<Image image="hud_1" height="700" width="1000"/>
	<TableLayout width="850" height="610" rectAlignment="MiddleCenter" cellSpacing="0" cellPadding="0" columnWidths="400 50 400">
		<!-- Тайтл -->
		<Row preferredHeight="80">
			<Cell columnSpan="3" dontUseTableCellBackground="true">
				<text id="MM_addonTitle_text" text="" fontSize="46" fontStyle="bold" alignment="MiddleCenter"/>
			</Cell>
		</Row>
		<!-- Контент: [left][spacer][right] висота 530px -->
		<Row preferredHeight="530">
			<!-- LEFT: картинка + резюме зверху, опис заповнює решту -->
			<Cell dontUseTableCellBackground="true">
				<panel width="400" height="530">
					<HorizontalLayout
						rectAlignment="UpperCenter"
						width="400"
						height="190"
						spacing="20"
						childForceExpandWidth="false"
						childAlignment="MiddleLeft">
						<image id="addonImage" image="addon1" width="180" preserveAspect="true"/>
						<text id="MM_addonSummary_text" fontSize="20" alignment="MiddleLeft"/>
					</HorizontalLayout>
					<VerticalScrollView
						rectAlignment="LowerCenter"
						width="400"
						height="330"
						color="clear"
						verticalScrollbarVisibility="AutoHideAndExpandViewport"
						verticalScrollbarWidth="20"
						raycastTarget="true"
						scrollSensitivity="30">
						<VerticalLayout contentSizeFitter="vertical">
							<text id="MM_addonDescription_text" fontSize="20" fontStyle="italic"/>
						</VerticalLayout>
					</VerticalScrollView>
				</panel>
			</Cell>
			<!-- SPACER -->
			<Cell dontUseTableCellBackground="true"/>
			<!-- RIGHT: список зверху, кнопка знизу -->
			<Cell dontUseTableCellBackground="true">
				<panel width="400" height="530">
					<VerticalScrollView
						rectAlignment="UpperCenter"
						width="400"
						height="428"
						color="clear"
						verticalScrollbarVisibility="AutoHideAndExpandViewport"
						verticalScrollbarWidth="20"
						raycastTarget="true"
						scrollSensitivity="30">
						<VerticalLayout contentSizeFitter="vertical" width="380" spacing="10">
							<panel id="addon_panel1" preferredHeight="50" color="#ffffff22">
								<button id="addon1" onClick="selectAddon" onMouseEnter="previewAddon"/>
								<text id="MM_text_addon1_text" alignment="MiddleCenter" text=""/>
							</panel>
							<panel id="addon_panel2" preferredHeight="50">
								<button id="addon2" onClick="selectAddon" onMouseEnter="previewAddon"/>
								<text id="MM_text_addon2_text" alignment="MiddleCenter" text=""/>
							</panel>
							<panel id="addon_panel3" preferredHeight="50">
								<button id="addon3" onClick="selectAddon" onMouseEnter="previewAddon"/>
								<text id="MM_text_addon3_text" alignment="MiddleCenter" text=""/>
							</panel>
							<panel id="addon_panel4" preferredHeight="50">
								<button id="addon4" onClick="selectAddon" onMouseEnter="previewAddon"/>
								<text id="MM_text_addon4_text" alignment="MiddleCenter" text=""/>
							</panel>
						</VerticalLayout>
					</VerticalScrollView>
					<panel rectAlignment="LowerCenter" width="400" height="92">
						<Button
							id="MM_submitAddons_text"
							onClick="submitAddons"
							width="400"
							height="92"
							color="clear"
							text=""/>
						<image width="400" preserveAspect="true" image="button_large"/>
					</panel>
				</panel>
			</Cell>
		</Row>
	</TableLayout>
</panel>

