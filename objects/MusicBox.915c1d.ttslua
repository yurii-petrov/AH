    font_size=300
  })

  self.createButton({
    click_function = 'autostart',
    function_owner = self,
    label          = autobutton,
    position       = {-0.24,0.6,-0.4},
    rotation       = {0,180,0},
    width          = 1700,
    height         = 400,
    tooltip        = '',
    scale          = {0.13,0.13,0.13},
    color          = {0,0,0},
    hover_color    = {0.3,0.3,0.3},
    press_color    = {0,0,0},
    font_color     = {1,1,1},
    font_size=300
  })


end


function onlyonesong()
current_clip = MusicPlayer.playlist_index
if string.match(self.script_state, "onesong") then
if string.match(self.script_state, "autostart") then
self.script_state = "allsongsautostart"
self.editButton({index=6, label="allsongs"})
else
self.script_state = "allsongs"
self.editButton({index=6, label="allsongs"})
end
else
if string.match(self.script_state, "autostart") then
self.script_state = "onesongautostart"
self.editButton({index=6, label="onesong"})
else
self.script_state = "onesong"
self.editButton({index=6, label="onesong"})
end
end
end



function autostart()
if string.match(self.script_state, "onesong") then
if string.match(self.script_state, "autostart") then
self.script_state = "onesong"
self.editButton({index=7, label="stop at load"})
else
self.script_state = "onesongautostart"
self.editButton({index=7, label="play at load"})
end
else
if string.match(self.script_state, "autostart") then
self.script_state = "allsongs"
self.editButton({index=7, label="stop at load"})
else
self.script_state = "allsongsautostart"
self.editButton({index=7, label="play at load"})
end
end
end


function keine_funktion()
end
function play_track()
pausedas = 0
current_clip = MusicPlayer.playlist_index
   MusicPlayer.play()

end

function next_track()
  MusicPlayer.skipForward()
current_clip = MusicPlayer.playlist_index
pausedas = 1

end

function previous_track()
current_clip = MusicPlayer.playlist_index
pausedas = 1
  if current_clip > 0 then
    MusicPlayer.skipBack()
    current_clip = MusicPlayer.playlist_index
  else
    MusicPlayer.pause()
  end
end


function pause_track()
MusicPlayer.pause()
end

function countCards()
audio_check = MusicPlayer.playlist_index
if pausedas == 1 then
    MusicPlayer.pause()
end
if current_clip ~= audio_check  and string.match(self.script_state, "onesong") then
    MusicPlayer.pause()
  end
local clip = MusicPlayer.getCurrentAudioclip()

if string.len(clip.title) > 13 then
shortenclip = string.sub(clip.title, 1, 10) .. ".."
else
shortenclip = clip.title
end

 self.editButton({index=4, label=MusicPlayer.playlistIndex .. ". " .. shortenclip})

end
