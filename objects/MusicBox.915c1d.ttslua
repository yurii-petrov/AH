function onLoad()
if string.match(self.script_state, "onesong") then
goonbutton = "onesong"
else
goonbutton = "allsongs"
end

if string.match(self.script_state, "autostart") then
autobutton = "play at load"
else
autobutton = "stop at load"
end

pausedas = 0
current_clip = MusicPlayer.playlistIndex

timerID = self.getGUID()..math.random(9999999999999)

Timer.create({
        identifier=timerID,
        function_name="countCards", function_owner=self,
        repetitions=0, delay=0.1
    })

if string.match(self.script_state, "autostart") then

local playlist = MusicPlayer.getPlaylist()

MusicPlayer.setCurrentAudioclip({
    url = playlist[1].url,
    title = playlist[1].title
})


MusicPlayer.play()
end

  self.createButton({
    click_function = 'play_track',
    function_owner = self,
    label          = '>',
    position       = {0.07,0.6,-0.18},
    rotation       = {0,180,0},
    width          = 800,
    height         = 1000,
    tooltip        = '',
