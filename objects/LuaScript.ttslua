function updateXMLs()
  i18n.updateGlobalUiLanguage()
  i18n.updateAllObjectsUiLanguage()
end

function updateGlobalXml(newXml)
  local windowIdList = {"languages", "main_menu"}

  for _, windowId in ipairs(windowIdList) do
    local element = getXmlTableElementById(newXml, windowId)
    if windowId == "main_menu" then
      element.attributes.active = gameData.language and not gameData.isStarted
    elseif windowId == "languages" then
      element.attributes.active = gameData.language == nil
    end
  end

  self.UI.setAttribute('title', 'text', i18n.getStrById("MM_scenario1_name_text"))
  self.UI.setAttribute('body', 'text', i18n.getStrById("MM_scenario1_desc_text"))
  self.UI.setXmlTable(newXml)
end

