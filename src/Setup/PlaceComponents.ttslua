-- Deals item cards from the item deck to the shop mat display slots.
-- Resolves the deck object via stored GUID; falls back to Physics.cast at the
-- item deck position and updates the stored GUID if found there.
function showMerchandise()
  local shopMat = SHOP_MAT_DATA.obj
  if not shopMat then return end

  local deckData = SHOP_MAT_DATA.decks[ShopDeckType.ITEM]
  if not deckData then return end

  local obj = deckData.guid and getObjectFromGUID(deckData.guid)

  if not obj then
    local pos = shopMat.positionToWorld(deckData.pos):setAt("y", 3)
    local hits = Physics.cast({
      origin       = Vector(pos.x, pos.y + 2, pos.z),
      direction    = {0, -1, 0},
      type         = 2,
      size         = {1, 1, 1},
      max_distance = 3,
    })
    for _, hit in ipairs(hits) do
      local o = hit.hit_object
      if o and (o.type == "Deck" or o.type == "Card") then
        obj = o
        deckData.guid = o.getGUID()
        break
      end
    end
  end

  if not obj then return end

  for idx, localPos in ipairs(SHOP_MAT_DATA.displaypos) do
    local worldPos = shopMat.positionToWorld(localPos):setAt("y", 3)
    local card = obj.takeObject({ index = 0, rotation = {0, 180, 0}, position = worldPos })
    if card then
      local itemData = parseJson(card.memo)
      if itemData then
        local types = {}
        if itemData.common then table.insert(types, "common") end
        if itemData.curio  then table.insert(types, "curio")  end
        shopMat.call("setBottom", { id = idx, price = itemData.price or 0, guid = card.guid })
        shopMat.call("setTop",    { id = idx, types = types })
      end
    end
  end
end

-- headline deck → locationMat headline slot; merge addons, shuffle, trim to 13
local function placeHeadlineCards(done)
  local locationMat = LOCATION_MAT_DATA.obj
  if not locationMat then done() return end
  if not LOCATION_MAT_DATA.headline then done() return end
  local pos = locationMat.positionToWorld(LOCATION_MAT_DATA.headline):setAt("y", 3)

  local entries = collectEntries(BagType.HEADLINE_CARDS)
  for i in pairs(entries) do
    consumeComponent(BagType.HEADLINE_CARDS, i)
  end

  local model = buildDeckModel(entries)
  if not model.base then done() return end

  mergeDeckStack(BagType.HEADLINE_CARDS, model, pos, {0, 180, 180}, function(obj)
    -- if obj.type == "Deck" then obj.shuffle() end
    obj.setRotation({0, 180, 0})
    local box = resolve(boxId)
    Wait.time(function()
      if obj and obj.getQuantity and box then
        local extra = obj.getQuantity() - 13
        for _ = 1, extra do
          obj.takeObject({ index = 0, position = box.getPosition():setAt("y", 3), smooth = false })
        end
      end
      done()
    end, 1)
  end)
end

-- event deck: pick the one whose memo.name matches scenarioData.name
local function placeEventCards(done)
  local scenarioData = gameData.scenarioData
  if not scenarioData then done() return end

  local scenarioMat = SCENARIO_MAT_DATA.obj
  if not scenarioMat then done() return end
  local matData = parseJson(scenarioMat.memo)
  if not matData or not matData.scenarios then done() return end

  local scenarioInstruction = matData.scenarios[scenarioData.number]
  if not scenarioInstruction then done() return end

  local pos
  for _, d in ipairs(scenarioInstruction.decks or {}) do
    if string.lower(d.type or "") == "event" then
      if matData.positions and matData.positions[d.pos] then
        pos = scenarioMat.positionToWorld(matData.positions[d.pos]):setAt("y", 3)
      end
      break
    end
  end

  local entries = collectEntries(BagType.EVENT_CARDS)
  for i, entry in pairs(entries) do
    local eName = entry.memo and entry.memo.name and string.lower(entry.memo.name) or ""
    local sName = string.lower(scenarioData.name or "")
    if eName == sName and pos then
      local eventObj = spawnComponent(BagType.EVENT_CARDS, entry, pos, {0, 180, 180})
      if eventObj then
        local placedDecks = {}  -- populated by encounter deck placement earlier (none yet here)
        prepareScenarioEventDeck(eventObj, placedDecks, 0.5)
      end
      consumeComponent(BagType.EVENT_CARDS, i)
    end
    -- non-matching events left unconsumed → cleanup
  end
  done()
end

local function placeEncounterCards(done)
  local scenarioData = gameData.scenarioData
  if not scenarioData then done() return end

  local scenarioMat = SCENARIO_MAT_DATA.obj
  if not scenarioMat then done() return end

  local scenInfo = SCENARIO_MAT_DATA.scenarios[scenarioData.name]
  if not scenInfo then done() return end

  local encounters = scenInfo.encounter or {}
  local entries    = collectEntries(BagType.ENCOUNTER_CARDS)

  -- group by deck name, discard inactive addons immediately
  local groups    = {}  -- [name] = { pos, keys[], entries[] }
  local nameOrder = {}
  for i, entry in pairs(entries) do
    local addonState = entry.memo and entry.memo.set and gameData.addons[entry.memo.set]
    if entry.memo and entry.memo.set and addonState == false then
      consumeComponent(BagType.ENCOUNTER_CARDS, i)
    else
      local name   = entry.memo and entry.memo.name or ""
      local posIdx = encounters[name]
      if posIdx then
        if not groups[name] then
          groups[name] = {
            pos     = scenarioMat.positionToWorld(SCENARIO_MAT_DATA.positions[posIdx]):setAt("y", 3),
            keys    = {},
            entries = {},
          }
          table.insert(nameOrder, name)
        end
        table.insert(groups[name].keys, i)
        table.insert(groups[name].entries, entry)
      end
    end
  end

  local function processNext(idx)
    if idx > #nameOrder then done() return end
    local name  = nameOrder[idx]
    local group = groups[name]

    for _, k in ipairs(group.keys) do
      consumeComponent(BagType.ENCOUNTER_CARDS, k)
    end

    local model = buildDeckModel(group.entries)
    if not model.base then processNext(idx + 1) return end

    mergeDeckStack(BagType.ENCOUNTER_CARDS, model, group.pos, {0, 180, 180}, function(obj)
      obj.setName(name)
      processNext(idx + 1)
    end, name)
  end

  processNext(1)
end

-- archive decks → locationMat archive slot; merge addon sets; flip face-up
local function placeArchiveDecks(done)
  local locationMat = LOCATION_MAT_DATA.obj
  if not locationMat then done() return end
  if not LOCATION_MAT_DATA.archive then done() return end
  local archivePos = locationMat.positionToWorld(LOCATION_MAT_DATA.archive):setAt("y", 3)

  local entries = collectEntries(BagType.ARCHIVE_DECKS)
  for i in pairs(entries) do
    consumeComponent(BagType.ARCHIVE_DECKS, i)
  end

  local model = buildDeckModel(entries)
  if not model.base then done() return end

  mergeDeckStack(BagType.ARCHIVE_DECKS, model, archivePos, {0, 180, 180}, function(obj)

    done()
  end)
end

-- place investigator sheets in a row near the location mat for player selection
local function placeInvestigatorSheets(done)
  if not gameData.directSetup then done() return end
  local locationMat = LOCATION_MAT_DATA.obj
  if not locationMat then done() return end

  local entries   = collectEntries(BagType.INVESTIGATOR_SHEETS)
  local matPos    = locationMat.getPosition()
  local spacing   = 4
  local totalWidth = (#entries - 1) * spacing
  local startX     = matPos.x - totalWidth / 2

  for i, entry in pairs(entries) do
    local pos = Vector(startX + (i - 1) * spacing, matPos.y + 2, matPos.z + 25)
    local o = spawnComponent(BagType.INVESTIGATOR_SHEETS, entry, pos, {0, 180, 0})
    if o then
      runAfterRest(o, function(o2)
        o2.setRotation({0, 180, 0})
      end)
    end
    consumeComponent(BagType.INVESTIGATOR_SHEETS, i)
  end
  done()
end

local function placeReferenceCards(done)
  local entry = getComponents(BagType.REFERENCE_CARDS)[1]
  if not entry then done() return end
  consumeComponent(BagType.REFERENCE_CARDS, 1)

  local locationMat = LOCATION_MAT_DATA.obj
  if not locationMat then done() return end

  local numPlayers = gameData.numberOfPlayers or 2
  local spacing    = 14.5
  local centerX    = locationMat.getPosition().x
  local startX     = centerX - ((numPlayers - 1) * spacing) / 2

  local deck = spawnComponent(BagType.REFERENCE_CARDS, entry,
    locationMat.getPosition():setAt("y", 3), {0, 180, 180})
  if not deck then done() return end

  Wait.time(function()
    for i = 1, numPlayers do
      local xPos = startX + (i - 1) * spacing
      deck.takeObject({ index = 0, position = Vector(xPos, 3, -71), smooth = true })
    end
    done()
  end, 0.5)
end

-- ╭──────────────────────────────────────────────╮
-- │               MAIN ENTRY POINT               │
-- ╰──────────────────────────────────────────────╯

function placeComponents()
  local steps = {
    placeScenarioSheets,
    placeMapTiles,
    placeSpecialCards,
    placeAllyCards,
    placeSpellCards,
    placeItemCards,
    placeConditionCards,
    placeEncounterCards,
    placeAnomalyCards,
    placeTerrorCards,
    placeArchiveDecks,
    placeMonsterDecks,
    placeHeadlineCards,
    placeEventCards,
    placeReferenceCards,
    cleanupComponents,
  }
  local function next(i)
    if i > #steps then return end
    steps[i](function() next(i + 1) end)
  end
  next(1)
end
