-- ╭──────────────────────────────────────────────╮
-- │         PLACE COMPONENTS ON GAME START       │
-- ╰──────────────────────────────────────────────╯
--
-- Called from proceedStartGame after scenario is chosen.
-- Works with gameData.components[bagType] = { {guid, name, memo}, ... }
--
-- Normal mode : guid is an object already on the table
--               → getObjectFromGUID(guid) + setPositionSmooth
-- Quick mode  : guid is an object inside a component bag
--               → bag.takeObject({ guid = guid, position = pos })

-- ╭──────────────────────────────────────────────╮
-- │                  HELPERS                     │
-- ╰──────────────────────────────────────────────╯

local function getComponents(bagType)
  return gameData.components and gameData.components[bagType] or {}
end

local function consumeComponent(bagType, key)
  if gameData.components and gameData.components[bagType] then
    gameData.components[bagType][key] = nil
  end
end

local KEEP_ON_TABLE = {
  [BagType.MAP_TILES]           = true,
  [BagType.INVESTIGATOR_SHEETS] = true,
  [BagType.STARTING_CARDS]      = true,
}

local function cleanupComponents(done)
  local box = resolve(boxId)
  if not box then if done then done() end return end

  for bagType, entries in pairs(gameData.components or {}) do
    if not KEEP_ON_TABLE[bagType] then
      for key, entry in pairs(entries) do
        if not gameData.directSetup then
          local o = getObjectFromGUID(entry.guid)
          if o then box.putObject(o) end
        end
        entries[key] = nil
      end
    end
  end

  if done then done() end
end

local function spawnComponent(bagType, entry, pos, rot)
  if gameData.directSetup then
    local bagGuid = gameData.componentBags and gameData.componentBags[bagType]
    if not bagGuid then return nil end
    local bag = getObjectFromGUID(bagGuid)
    if not bag then return nil end
    return bag.takeObject({
      guid     = entry.guid,
      position = pos,
      rotation = rot,
      smooth   = false,
    })
  else
    local o = getObjectFromGUID(entry.guid)
    if not o then return nil end
    if pos then o.setPosition(pos) end
    if rot then o.setRotation(rot) end
    return o
  end
end

-- snapshot entries before consuming so iteration is safe
local function collectEntries(bagType)
  local result = {}
  for i, entry in ipairs(getComponents(bagType)) do
    result[i] = entry
  end
  return result
end


-- ── deck model builder ────────────────────────────────────────────────────────
-- Splits array of entries into:
--   base      – no-set entry, OR smallest active-set entry if all have sets
--   additions – remaining active-set entries to merge into base
--   inactive  – disabled addon entries (cleanup handles them)
local function buildDeckModel(entries)
  local noSet  = {}
  local bySets = {}   -- { set=number, entry=entry }

  for _, e in ipairs(entries) do
    local s = e.memo and e.memo.set
    if not s then
      table.insert(noSet, e)
    else
      table.insert(bySets, { set = s, entry = e })
    end
  end

  table.sort(bySets, function(a, b) return a.set < b.set end)

  local base      = noSet[1]
  local additions = {}
  local inactive  = {}

  for i = 2, #noSet do table.insert(additions, noSet[i]) end

  for _, item in ipairs(bySets) do
    local active = gameData.addons[item.set]
    if active == false then
      table.insert(inactive, item.entry)
    else
      if not base then
        base = item.entry
      else
        table.insert(additions, item.entry)
      end
    end
  end

  return { base = base, additions = additions, inactive = inactive }
end

-- ╭──────────────────────────────────────────────╮
-- │            DECK MERGE STRATEGIES            │
-- ╰──────────────────────────────────────────────╯

-- Strategy 1: spawn base → putObject each addition sequentially.
-- Use when you need to control what becomes the base object (e.g. face-up flip after merge).
local MERGE_DELAY        = 0.1
local STACK_SETTLE_DELAY = 0.3

local function mergeDeckSequential(bagType, model, pos, rot, onFinish)
  local baseObj = spawnComponent(bagType, model.base, pos, rot)
  if not baseObj then return end

  local function mergeNext(obj, idx)
    if idx > #model.additions then
      if onFinish then onFinish(obj) end
      return
    end
    local src = spawnComponent(bagType, model.additions[idx], obj.getPosition(), rot)
    if src then
      local merged = obj.putObject(src)
      Wait.time(function() mergeNext(merged or obj, idx + 1) end, 0)
    else
      mergeNext(obj, idx + 1)
    end
  end

  if #model.additions == 0 then
    if onFinish then Wait.time(function() onFinish(baseObj) end, 0) end
  else
    Wait.time(function() mergeNext(baseObj, 1) end, 0)
  end
end

-- Strategy 2: spawn all decks at staggered y positions (largest addon first, base last).
-- Each addon is +0.2 above the previous so TTS merges them as they settle.
-- description (optional) is set immediately on the base object when spawned.
-- When addons are present the physical merge creates a NEW object, so onFinish receives
-- the result of a Physics.cast at pos after STACK_SETTLE_DELAY rather than the stale baseObj.
local function mergeDeckStack(bagType, model, pos, rot, onFinish, description)
  local function findAndFinish()
    if not onFinish then return end
    local hits = Physics.cast({
      origin       = Vector(pos.x, pos.y + 2, pos.z),
      direction    = {0, -1, 0},
      type         = 2,
      size         = {1, 1, 1},
      max_distance = 3,
    })
    for _, hit in ipairs(hits) do
      local o = hit.hit_object
      if o and (o.type == "Deck" or o.type == "Card") then
        onFinish(o)
        return
      end
    end
  end

  local basePos = Vector(pos.x, pos.y + 3.05, pos.z)

  local function spawnNext(i)
    if i < 1 then
      local baseObj = spawnComponent(bagType, model.base, basePos, rot)
      if not baseObj then return end
      if description then baseObj.setName(description) end
      Wait.time(findAndFinish, STACK_SETTLE_DELAY)
      return
    end
    local addonPos = Vector(pos.x, pos.y + i * 0.2, pos.z)
    spawnComponent(bagType, model.additions[i], addonPos, rot)
    Wait.time(function() spawnNext(i - 1) end, MERGE_DELAY)
  end

  if #model.additions == 0 then
    local baseObj = spawnComponent(bagType, model.base, basePos, rot)
    if not baseObj then return end
    if description then baseObj.setName(description) end
    if onFinish then Wait.time(function() onFinish(baseObj) end, MERGE_DELAY) end
  else
    spawnNext(#model.additions)
  end
end

-- ╭──────────────────────────────────────────────╮
-- │           PER-TYPE PLACE FUNCTIONS           │
-- ╰──────────────────────────────────────────────╯

local function placeMapTiles(done)
  local scenarioData = gameData.scenarioData
  if not scenarioData or not scenarioData.tiles then done() return end

  local mapBagGuid = gameData.componentBags and gameData.componentBags[BagType.MAP_TILES]
  local bag    = gameData.directSetup and mapBagGuid and getObjectFromGUID(mapBagGuid)
  local idx    = 0

  for _, entry in ipairs(getComponents(BagType.MAP_TILES)) do
    local o
    if gameData.directSetup then
      if not bag then break end
      local tempPos = bag.getPosition():setAt("y", 3) + Vector(idx * 5, 0, 0)
      idx = idx + 1
      o = bag.takeObject({ guid = entry.guid, position = tempPos, smooth = false })
      if o then
        runAfterRest(o, function(o2)
          lockSetupScenarioComponents(o2, scenarioData.tiles)
        end)
      end
    else
      o = getObjectFromGUID(entry.guid)
      if o then lockSetupScenarioComponents(o, scenarioData.tiles) end
    end
  end
  done()
end

local function placeScenarioSheets(done)
  local scenarioData = gameData.scenarioData
  if not scenarioData then
    log("[placeScenarioSheets] gameData.scenarioData is nil")
    done() return
  end

  local locationMat = LOCATION_MAT_DATA.obj
  if not locationMat then
    log("[placeScenarioSheets] locationMat not found")
    done() return
  end

  local locationData = parseJson(locationMat.memo)
  if not locationData then
    log("[placeScenarioSheets] locationMat memo is nil or invalid")
    done() return
  end
  if not locationData.scenraiomat then
    log("[placeScenarioSheets] locationData.scenraiomat is nil")
    done() return
  end

  local sheets = getComponents(BagType.SCENARIO_SHEETS)
  local entry  = sheets[scenarioData.name]
  if not entry then
    log("[placeScenarioSheets] no entry for scenario name='" .. tostring(scenarioData.name) .. "'")
    log("[placeScenarioSheets] available keys:")
    for k in pairs(sheets) do log("  - " .. tostring(k)) end
    done() return
  end

  consumeComponent(BagType.SCENARIO_SHEETS, scenarioData.name)

  local targetPos = locationMat.positionToWorld(locationData.scenraiomat):setAt("y", 2.21)
  local o = spawnComponent(BagType.SCENARIO_SHEETS, entry, targetPos, {0, 180, 0})
  if not o then
    log("[placeScenarioSheets] spawnComponent returned nil for guid=" .. tostring(entry.guid))
    done() return
  end

  runAfterRest(o, function(o2) o2.setLock(true) end)
  done()
end

local function placeAllyCards(done)
  local shopMat = SHOP_MAT_DATA.obj
  if not shopMat then done() return end
  local deckData = SHOP_MAT_DATA.decks[ShopDeckType.ALLY]
  if not deckData then done() return end
  local pos = shopMat.positionToWorld(deckData.pos):setAt("y", 2.5)

  local model = buildDeckModel(collectEntries(BagType.ALLY_CARDS))
  if not model.base then done() return end

  for i in pairs(collectEntries(BagType.ALLY_CARDS)) do
    consumeComponent(BagType.ALLY_CARDS, i)
  end

  mergeDeckStack(BagType.ALLY_CARDS, model, pos, {0, 180, 180}, function(obj)
    SHOP_MAT_DATA.decks[ShopDeckType.ALLY].guid = obj.getGUID()
    done()
  end, ShopDeckType.ALLY)
end

local function placeAnomalyCards(done)
  local scenarioData = gameData.scenarioData
  if not scenarioData then done() return end

  local scenarioMat = SCENARIO_MAT_DATA.obj
  if not scenarioMat then done() return end

  local scenInfo = SCENARIO_MAT_DATA.scenarios[scenarioData.name]
  if not scenInfo or not scenInfo.anomaly then done() return end

  local entries   = collectEntries(BagType.ANOMALY_CARDS)
  local anomalies = scenInfo.anomaly

  -- group by deck name
  local groups    = {}  -- [name] = { pos, keys[], entries[] }
  local nameOrder = {}
  for i, entry in pairs(entries) do
    local name   = entry.memo and entry.memo.name or ""
    local posIdx = anomalies[name]
    if posIdx then
      if not groups[name] then
        groups[name] = {
          pos     = scenarioMat.positionToWorld(SCENARIO_MAT_DATA.positions[posIdx]):setAt("y", 3),
          keys    = {},
          entries = {},
        }
        table.insert(nameOrder, name)
      end
      table.insert(groups[name].keys, i)
      table.insert(groups[name].entries, entry)
    end
  end

  local function processNext(idx)
    if idx > #nameOrder then done() return end
    local name  = nameOrder[idx]
    local group = groups[name]

    for _, k in ipairs(group.keys) do
      consumeComponent(BagType.ANOMALY_CARDS, k)
    end

    local model = buildDeckModel(group.entries)
    if not model.base then processNext(idx + 1) return end

    mergeDeckStack(BagType.ANOMALY_CARDS, model, group.pos, {0, 180, 180}, function(obj)
      obj.setName(name)
      processNext(idx + 1)
    end, name)
  end

  processNext(1)
end

local function placeTerrorCards(done)
  local scenarioData = gameData.scenarioData
  if not scenarioData then done() return end

  local scenarioMat = SCENARIO_MAT_DATA.obj
  if not scenarioMat then done() return end

  local scenInfo = SCENARIO_MAT_DATA.scenarios[scenarioData.name]
  if not scenInfo or not scenInfo.terror then done() return end

  local entries  = collectEntries(BagType.TERROR_CARDS)
  local terrors  = scenInfo.terror

  local groups    = {}
  local nameOrder = {}
  for i, entry in pairs(entries) do
    local name   = entry.memo and entry.memo.name or ""
    local posIdx = terrors[name]
    if posIdx then
      if not groups[name] then
        groups[name] = {
          pos     = scenarioMat.positionToWorld(SCENARIO_MAT_DATA.positions[posIdx]):setAt("y", 3),
          keys    = {},
          entries = {},
        }
        table.insert(nameOrder, name)
      end
      table.insert(groups[name].keys, i)
      table.insert(groups[name].entries, entry)
    end
  end

  local function processNext(idx)
    if idx > #nameOrder then done() return end
    local name  = nameOrder[idx]
    local group = groups[name]

    for _, k in ipairs(group.keys) do
      consumeComponent(BagType.TERROR_CARDS, k)
    end

    local model = buildDeckModel(group.entries)
    if not model.base then processNext(idx + 1) return end

    mergeDeckStack(BagType.TERROR_CARDS, model, group.pos, {0, 180, 180}, function(obj)
      obj.setName(name)
      processNext(idx + 1)
    end, name)
  end

  processNext(1)
end

