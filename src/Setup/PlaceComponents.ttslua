  mergeDeckStack(BagType.SPECIAL_CARDS, model, pos, {0, 180, 180}, function(obj)
    SHOP_MAT_DATA.decks[ShopDeckType.SPECIAL].guid = obj.getGUID()
  end, ShopDeckType.SPECIAL)
end

local function placeMonsterDecks()
  local scenarioData = gameData.scenarioData
  if not scenarioData or not scenarioData.monsterdeck then return end

  local locationMat = LOCATION_MAT_DATA.obj
  if not locationMat then return end
  local locationData = parseJson(locationMat.memo)
  if not locationData then return end

  local positions = {
    main      = locationMat.positionToWorld(locationData.monster):setAt("y", 3),
    setaside  = locationMat.positionToWorld(locationData.setaside):setAt("y", 3),
    setaside2 = locationMat.positionToWorld(locationData.setaside2):setAt("y", 3),
  }

  local entries   = collectEntries(BagType.MONSTER_DECKS)
  local spawned   = {}
  local spreadIdx = 0
  local basePos   = locationMat.getPosition()

  for i, entry in pairs(entries) do
    local addonState = entry.memo and entry.memo.set and gameData.addons[entry.memo.set]
    if entry.memo and entry.memo.set and addonState == false then
      -- addon disabled → cleanupComponents will discard
    else
      local spawnPos = Vector(basePos.x + spreadIdx * 3, basePos.y + 3, basePos.z - 7)
      spreadIdx = spreadIdx + 1
      local o = spawnComponent(BagType.MONSTER_DECKS, entry, spawnPos, {0, 180, 180})
      if o then table.insert(spawned, o) end
      consumeComponent(BagType.MONSTER_DECKS, i)
    end
  end

  if #spawned == 0 then return end

  Wait.time(function()
    local main = spawned[1]
    for k = 2, #spawned do
      main.putObject(spawned[k])
    end
    Wait.time(function()
      local counters      = buildMonsterDeckSelectionCounters(scenarioData)
      local objectsToTake = buildMonsterObjectsToTake(main, counters, positions)
      for _, data in ipairs(objectsToTake) do
        takeAndPlaceMonsterCard(main, data, counters.spawn, positions)
      end
      Wait.time(function()
        finalizeMonsterDecks(positions, main)
      end, 2)
    end, 1)
  end, 1)
end

local function placeStartingCards()
  local shopMat = SHOP_MAT_DATA.obj
  if not shopMat then return end
  local deckData = SHOP_MAT_DATA.decks[ShopDeckType.STARTING]
  if not deckData then return end
  local pos = shopMat.positionToWorld(deckData.pos):setAt("y", 2.5)

  local model = buildDeckModel(collectEntries(BagType.STARTING_CARDS))
  if not model.base then return end

  for i in pairs(collectEntries(BagType.STARTING_CARDS)) do
    consumeComponent(BagType.STARTING_CARDS, i)
  end

  mergeDeckStack(BagType.STARTING_CARDS, model, pos, {0, 180, 180}, function(obj)
    SHOP_MAT_DATA.decks[ShopDeckType.STARTING].guid = obj.getGUID()
  end, ShopDeckType.STARTING)
end

function addConditionMat2()
  local matData = CONDITION_MAT_DATA[2]
  if not matData or not matData.guid then return end
  local mat = matData.obj
  if not mat then return end
  local pos = mat.getPosition()
  mat.setPosition(Vector(pos.x, 2, pos.z))
end

local function placeConditionCards()
  local entries = collectEntries(BagType.CONDITION_CARDS)
  for i, entry in pairs(entries) do
    local t = entry.memo and string.lower(entry.memo.type or "") or ""
    for _, matData in ipairs(CONDITION_MAT_DATA) do
      if matData.obj and matData.deck[t] then
        local mat = matData.obj
        if mat then
          local pos = mat.positionToWorld(matData.deck[t]):setAt("y", 3)
          local o = spawnComponent(BagType.CONDITION_CARDS, entry, pos, {0, 180, 180})
          if o and t ~= "" then o.setName(t) end
          consumeComponent(BagType.CONDITION_CARDS, i)
        end
        break
      end
    end
  end
end

