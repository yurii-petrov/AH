  local entries  = collectEntries(BagType.TERROR_CARDS)
  local terrors  = scenInfo.terror

  local groups    = {}
  local nameOrder = {}
  for i, entry in pairs(entries) do
    local name   = entry.memo and entry.memo.name or ""
    local posIdx = terrors[name]
    if posIdx then
      if not groups[name] then
        groups[name] = {
          pos     = scenarioMat.positionToWorld(SCENARIO_MAT_DATA.positions[posIdx]):setAt("y", 3),
          keys    = {},
          entries = {},
        }
        table.insert(nameOrder, name)
      end
      table.insert(groups[name].keys, i)
      table.insert(groups[name].entries, entry)
    end
  end

  if #nameOrder == 0 then done() return end

  local remaining = #nameOrder
  for _, name in ipairs(nameOrder) do
    local group = groups[name]
    for _, k in ipairs(group.keys) do
      consumeComponent(BagType.TERROR_CARDS, k)
    end
    local model = buildDeckModel(group.entries)
    if not model.base then
      remaining = remaining - 1
      if remaining == 0 then done() end
    else
      mergeDeckStack(BagType.TERROR_CARDS, model, group.pos, {0, 180, 180}, function()
        registerDeck(group.pos, name, function(obj)
          gameData.deckGuids["terror_" .. name] = obj.getGUID()
        end)
        remaining = remaining - 1
        if remaining == 0 then done() end
      end)
    end
  end
end

