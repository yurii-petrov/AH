  local entries = collectEntries(BagType.TERROR_CARDS)
  for i, entry in pairs(entries) do
    local o = spawnComponent(BagType.TERROR_CARDS, entry, terrorBag.getPosition():setAt("y", 3), {0, 180, 0})
    if o then terrorBag.putObject(o) end
    consumeComponent(BagType.TERROR_CARDS, i)
