end

function addConditionMat2()
  local matData = CONDITION_MAT_DATA[2]
  if not matData or not matData.guid then return end
  local mat = matData.obj
  if not mat then return end
  local pos = mat.getPosition()
  mat.setPosition(Vector(pos.x, 2, pos.z))
end

local function placeConditionCards(done)
  local entries = collectEntries(BagType.CONDITION_CARDS)

  -- group entries by type, resolve mat position per group
  local groups   = {}  -- [t] = { pos, keys[], entries[] }
  local typeOrder = {}
  for i, entry in pairs(entries) do
    local t = entry.memo and string.lower(entry.memo.type or "") or ""
    for _, matData in ipairs(CONDITION_MAT_DATA) do
      if matData.obj and matData.deck[t] then
        if not groups[t] then
          groups[t] = {
            pos     = matData.obj.positionToWorld(matData.deck[t]):setAt("y", 3),
            keys    = {},
            entries = {},
          }
          table.insert(typeOrder, t)
        end
        table.insert(groups[t].keys, i)
        table.insert(groups[t].entries, entry)
        break
      end
    end
  end

  local function processNext(idx)
    if idx > #typeOrder then done() return end
    local t     = typeOrder[idx]
    local group = groups[t]

    for _, k in ipairs(group.keys) do
      consumeComponent(BagType.CONDITION_CARDS, k)
    end

    local model = buildDeckModel(group.entries)
    if not model.base then processNext(idx + 1) return end

    mergeDeckStack(BagType.CONDITION_CARDS, model, group.pos, {0, 180, 180}, function(obj)
      if t ~= "" then obj.setName(t) end
      processNext(idx + 1)
    end, t)
  end

  processNext(1)
end

