-- Deals item cards from the item deck to the shop mat display slots.
-- Resolves the deck object via stored GUID; falls back to Physics.cast at the
-- item deck position and updates the stored GUID if found there.
function showMerchandise()
  local shopMat = SHOP_MAT_DATA.obj
  if not shopMat then return end

  local deckData = SHOP_MAT_DATA.decks[ShopDeckType.ITEM]
  if not deckData then return end

  local obj = deckData.guid and getObjectFromGUID(deckData.guid)

  if not obj then
    local pos = shopMat.positionToWorld(deckData.pos):setAt("y", 3)
    local hits = Physics.cast({
      origin       = Vector(pos.x, pos.y + 2, pos.z),
      direction    = {0, -1, 0},
      type         = 2,
      size         = {1, 1, 1},
      max_distance = 3,
    })
    for _, hit in ipairs(hits) do
      local o = hit.hit_object
      if o and (o.type == "Deck" or o.type == "Card") then
        obj = o
        deckData.guid = o.getGUID()
        break
      end
    end
  end

  if not obj then return end

  for idx, localPos in ipairs(SHOP_MAT_DATA.displaypos) do
    local worldPos = shopMat.positionToWorld(localPos):setAt("y", 3)
    local card = obj.takeObject({ index = 0, rotation = {0, 180, 0}, position = worldPos })
    if card then
      local itemData = parseJson(card.memo)
      if itemData then
        local types = {}
        if itemData.common then table.insert(types, "common") end
        if itemData.curio  then table.insert(types, "curio")  end
        shopMat.call("setBottom", { id = idx, price = itemData.price or 0, guid = card.guid })
        shopMat.call("setTop",    { id = idx, types = types })
      end
    end
  end
end

-- headline deck → locationMat headline slot; trim to 13 cards
local function placeHeadlineCards()
  local locationMat = LOCATION_MAT_DATA.obj
  if not locationMat then return end
  local locationData = parseJson(locationMat.memo)
  if not locationData or not locationData.headline then return end
  local pos = locationMat.positionToWorld(locationData.headline):setAt("y", 3)

  local entries = collectEntries(BagType.HEADLINE_CARDS)
  for i, entry in pairs(entries) do
    local o = spawnComponent(BagType.HEADLINE_CARDS, entry, pos, {0, 180, 180})
    if o then
      if o.type == "Deck" then o.shuffle() end
      if shouldSetFaceUp(o, "headline") then
        runAfterRest(o, function(o2)
          o2.setRotation({0, 180, 0})
          local box = resolve(boxId)
          Wait.time(function()
            if o2 and o2.getQuantity and box then
              local extra = o2.getQuantity() - 13
              for _ = 1, extra do
                o2.takeObject({ index = 0, position = box.getPosition():setAt("y", 3), smooth = false })
              end
            end
          end, 1)
        end)
      end
    end
    consumeComponent(BagType.HEADLINE_CARDS, i)
  end
end

-- event deck: pick the one whose memo.name matches scenarioData.name
local function placeEventCards()
  local scenarioData = gameData.scenarioData
  if not scenarioData then return end

  local scenarioMat = SCENARIO_MAT_DATA.obj
  if not scenarioMat then return end
  local matData = parseJson(scenarioMat.memo)
  if not matData or not matData.scenarios then return end

  local scenarioInstruction = matData.scenarios[scenarioData.number]
  if not scenarioInstruction then return end

  local pos
  for _, d in ipairs(scenarioInstruction.decks or {}) do
    if string.lower(d.type or "") == "event" then
      if matData.positions and matData.positions[d.pos] then
        pos = scenarioMat.positionToWorld(matData.positions[d.pos]):setAt("y", 3)
      end
      break
    end
  end

  local entries = collectEntries(BagType.EVENT_CARDS)
  for i, entry in pairs(entries) do
    local eName = entry.memo and entry.memo.name and string.lower(entry.memo.name) or ""
    local sName = string.lower(scenarioData.name or "")
    if eName == sName and pos then
      local eventObj = spawnComponent(BagType.EVENT_CARDS, entry, pos, {0, 180, 180})
      if eventObj then
        local placedDecks = {}  -- populated by encounter deck placement earlier (none yet here)
        prepareScenarioEventDeck(eventObj, placedDecks, 0.5)
      end
      consumeComponent(BagType.EVENT_CARDS, i)
    end
    -- non-matching events left unconsumed → cleanup
  end
end

-- encounter decks: route by memo.type → scenarioMat deck position
local function placeEncounterCards()
  local scenarioData = gameData.scenarioData
  if not scenarioData then return end

  local scenarioMat = SCENARIO_MAT_DATA.obj
  if not scenarioMat then return end
  local matData = parseJson(scenarioMat.memo)
  if not matData or not matData.scenarios then return end

  local scenarioInstruction = matData.scenarios[scenarioData.number]
  if not scenarioInstruction then return end

  -- build type → world-position lookup
  local deckDefs = {}
  for _, d in ipairs(scenarioInstruction.decks or {}) do
    local t = string.lower(d.type or "")
    if t ~= "event" and matData.positions and matData.positions[d.pos] then
      local worldPos = scenarioMat.positionToWorld(matData.positions[d.pos]):setAt("y", 3)
      if d.name then
        deckDefs[t] = deckDefs[t] or { names = {} }
        deckDefs[t].names[string.lower(d.name)] = worldPos
      else
        deckDefs[t] = { pos = worldPos }
      end
    end
  end

  local entries = collectEntries(BagType.ENCOUNTER_CARDS)
  for i, entry in pairs(entries) do
    local t    = entry.memo and string.lower(entry.memo.type or "") or ""
    local name = entry.memo and entry.memo.name and string.lower(entry.memo.name) or ""
    local addonState = entry.memo and entry.memo.set and gameData.addons[entry.memo.set]
    if entry.memo and entry.memo.set and addonState == false then
      consumeComponent(BagType.ENCOUNTER_CARDS, i)
    else
      local def = deckDefs[t]
      if def then
        local pos = (def.names and def.names[name]) or def.pos
        if pos then
          local o = spawnComponent(BagType.ENCOUNTER_CARDS, entry, pos, {0, 180, 180})
          if o then
            runAfterRest(o, function(o2)
              if o2.type == "Deck" then o2.shuffle() end
              if shouldSetFaceUp(o2, t) then o2.setRotation({0, 180, 0}) end
            end)
          end
          consumeComponent(BagType.ENCOUNTER_CARDS, i)
        end
      end
    end
  end
end

-- archive decks → locationMat archive slot; merge addon sets; extract codex cards
local function placeArchiveDecks()
  local locationMat = LOCATION_MAT_DATA.obj
  if not locationMat then return end
  local locationData = parseJson(locationMat.memo)
  if not locationData or not locationData.archive then return end
  local archivePos = locationMat.positionToWorld(locationData.archive):setAt("y", 3)

  local entries = collectEntries(BagType.ARCHIVE_DECKS)

  -- split into base (no set) and addon sources, discard inactive addons
  local base    = nil
  local sources = {}
  for i, entry in pairs(entries) do
    local addonState = entry.memo and entry.memo.set and gameData.addons[entry.memo.set]
    if entry.memo and entry.memo.set and addonState == false then
      consumeComponent(BagType.ARCHIVE_DECKS, i)
    elseif not (entry.memo and entry.memo.set) then
      base = { key = i, entry = entry }
    else
      table.insert(sources, { key = i, entry = entry })
    end
  end

  if not base and #sources > 0 then base = table.remove(sources, 1) end
  if not base then return end

  consumeComponent(BagType.ARCHIVE_DECKS, base.key)
  local baseObj = spawnComponent(BagType.ARCHIVE_DECKS, base.entry, archivePos, {0, 180, 180})
  if not baseObj then return end

  local function finishArchive(obj)
    obj.setPosition(archivePos)
    -- extract codex cards for the current scenario
    local scenarioData = gameData.scenarioData
    if not scenarioData then return end
    if not locationData.codex then return end

    Wait.time(function()
      local function containsNumber(tbl, target)
        for _, v in pairs(tbl) do if v == target then return true end end
      end
      local archiveObjs = obj.getObjects and obj.getObjects() or {}
      for k = #archiveObjs, 1, -1 do
        local codex     = archiveObjs[k]
        local codexData = parseJson(codex.memo)
        if codexData and codexData.number and codexData.type and string.lower(codexData.type) == "codex" then
          if scenarioData.codex and containsNumber(scenarioData.codex, codexData.number) then
            local taken = obj.takeObject({ index = codex.index })
            attachCodexCard(taken, locationMat.positionToWorld(locationData.codex[1]):setAt("y", 3))
          elseif scenarioData.codexDeck and containsNumber(scenarioData.codexDeck, codexData.number) and locationData.codexDeck then
            obj.takeObject({
              index    = codex.index,
              position = locationMat.positionToWorld(locationData.codexDeck):setAt("y", 3),
              rotation = {0, 180, 0},
              smooth   = false,
            })
          end
        end
      end
    end, 2)
  end

  if #sources == 0 then
    runAfterRest(baseObj, finishArchive)
    return
  end

  local function mergeNext(obj, idx)
    if idx > #sources then
      finishArchive(obj)
      return
    end
    local src = sources[idx]
    consumeComponent(BagType.ARCHIVE_DECKS, src.key)
    local srcObj = spawnComponent(BagType.ARCHIVE_DECKS, src.entry, obj.getPosition(), {0, 180, 180})
    if srcObj then
      local merged = obj.putObject(srcObj)
      runAfterRest(merged or obj, function(o2) mergeNext(o2, idx + 1) end)
    else
      mergeNext(obj, idx + 1)
    end
  end

  runAfterRest(baseObj, function(o) mergeNext(o, 1) end)
end

-- place investigator sheets in a row near the location mat for player selection
local function placeInvestigatorSheets()
  local locationMat = LOCATION_MAT_DATA.obj
  if not locationMat then return end

  local entries   = collectEntries(BagType.INVESTIGATOR_SHEETS)
  local matPos    = locationMat.getPosition()
  local spacing   = 4
  local totalWidth = (#entries - 1) * spacing
  local startX     = matPos.x - totalWidth / 2

  for i, entry in pairs(entries) do
    local pos = Vector(startX + (i - 1) * spacing, matPos.y + 2, matPos.z + 25)
    local o = spawnComponent(BagType.INVESTIGATOR_SHEETS, entry, pos, {0, 180, 0})
    if o then
      runAfterRest(o, function(o2)
        o2.setRotation({0, 180, 0})
      end)
    end
    consumeComponent(BagType.INVESTIGATOR_SHEETS, i)
  end
end

local function placeReferenceCards()
  local entry = getComponents(BagType.REFERENCE_CARDS)[1]
  if not entry then return end

  local locationMat = LOCATION_MAT_DATA.obj
  if not locationMat then return end

  local centerPos = locationMat.getPosition()
  centerPos.z = centerPos.z - locationMat.getBoundsNormalized().size.z / 2

  local numPlayers = gameData.numberOfPlayers or 2
  local spacing    = 14.5
  local totalWidth = (numPlayers - 1) * spacing
  local startX     = centerPos.x - totalWidth / 2

  local deck = spawnComponent(BagType.REFERENCE_CARDS, entry, centerPos:setAt("y", 3), {0, 180, 180})
  if not deck then return end

  Wait.time(function()
    for i = 1, numPlayers do
      local pos = Vector(startX + (i - 1) * spacing, centerPos.y + 2.1, centerPos.z - 7.40)
      deck.takeObject({ index = 0, position = pos, smooth = true })
    end
  end, 0.5)
end

-- ╭──────────────────────────────────────────────╮
-- │               MAIN ENTRY POINT               │
-- ╰──────────────────────────────────────────────╯

function placeComponents()
  placeScenarioSheets()
  placeMapTiles()
  placeSpecialCards()
  
  placeAllyCards()
  placeSpellCards()
  placeItemCards()
  placeConditionCards()
