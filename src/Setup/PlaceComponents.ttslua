local function prepareMonsterDeck(done)
  local entries = collectEntries(BagType.MONSTER_DECKS)
  local model   = buildDeckModel(entries)
  if not model.base then done() return end

  local mpos = model.base.memo and model.base.memo.startPosition
  if not mpos then done() return end
  local deckPos = TABLE_DATA.obj.positionToWorld(mpos):setAt("y", 3)

  for i in pairs(entries) do
    consumeComponent(BagType.MONSTER_DECKS, i)
  end

  mergeDeckStack(BagType.MONSTER_DECKS, model, deckPos, {0, 180, 180}, function()
    monsterStagingPos = deckPos
    done()
  end)
end

function distributeMonsterCards(done)
  local scenarioData = gameData.scenarioData
  if not scenarioData or not scenarioData.monsters then done() return end

  if not monsterStagingPos then done() return end

  local p = monsterStagingPos
  local hits = Physics.cast({
    origin       = Vector(p.x, p.y + 3, p.z),
    direction    = {0, -1, 0},
    type         = 2,
    size         = {1, 1, 1},
    max_distance = 5,
  })
  local deck
  for _, hit in ipairs(hits) do
    local o = hit.hit_object
    if o and (o.type == "Deck" or o.type == "Card") then
      deck = o
      break
    end
  end
  if not deck then done() return end

  local locationMat = LOCATION_MAT_DATA.obj
  if not locationMat then done() return end

  local monsterPos   = locationMat.positionToWorld(LOCATION_MAT_DATA.monster):setAt("y", 3)
  local setasidePos  = locationMat.positionToWorld(LOCATION_MAT_DATA.setaside):setAt("y", 3)
  local setaside2Pos = locationMat.positionToWorld(LOCATION_MAT_DATA.setaside2):setAt("y", 3)

  local wantList = {}
  for _, m in ipairs(scenarioData.monsters) do
    table.insert(wantList, {
      matchName = m.name and string.lower(m.name) or nil,
      matchType = m.type and string.lower(m.type) or nil,
      dest      = m.dest,
      remaining = m.count or 1,
      pos       = m.pos,
      rot       = m.rot,
      location  = m.location
    })
  end

  local function hasMonsterType(monstertype, wantType)
    if type(monstertype) ~= "table" then return false end
    for _, t in ipairs(monstertype) do
      if string.lower(t) == wantType then return true end
    end
    return false
  end

  for _, card in ipairs(deck.getObjects()) do
    local memo   = parseJson(card.memo) or {}
    local cName  = string.lower(memo.name or card.name or "")

    for _, want in ipairs(wantList) do
      local matched = false
      if want.matchName and want.matchName == cName and want.remaining > 0 then
        matched = true
        want.remaining = want.remaining - 1
      elseif want.matchType and want.remaining > 0 and hasMonsterType(memo.monstertype, want.matchType) then
        matched = true
        want.remaining = want.remaining - 1
      end

      if matched then
        if want.dest == "spawn" then
          local tile = want.location and getNeighborhoodTile(want.location)
          local worldPos = tile.positionToWorld(want.pos):setAt("y", 3)
          local spawnedCard = deck.takeObject({ guid = card.guid, position = worldPos, smooth = false })
          if spawnedCard then
            Wait.time(function() spawnMonster(worldPos, spawnedCard) end, 0.1)
          end
        else
          local targetPos, targetRot
          if want.dest == "deck" then
            targetPos = monsterPos
            targetRot = {0, 180, 180}
          elseif want.dest == "setaside" then
            targetPos = setasidePos
            targetRot = {0, 180, 180}
          elseif want.dest == "setaside2" then
            targetPos = setaside2Pos
            targetRot = {0, 180, 180}
          end
          if targetPos then
            deck.takeObject({ guid = card.guid, position = targetPos, rotation = targetRot, smooth = false })
          end
        end
        break
      end
    end
  end

  registerDeck(monsterPos, "Monster", function(obj)
    LOCATION_MAT_DATA.monsterDeckObj  = obj
    LOCATION_MAT_DATA.monsterDeckGuid = obj.getGUID()
    gameData.deckGuids.monster         = obj.getGUID()
  end)

  done()
end

local function placeStartingCards(done)
  if not gameData.directSetup then done() return end
  local shopMat = SHOP_MAT_DATA.obj
  if not shopMat then done() return end
  local deckData = SHOP_MAT_DATA.decks[ShopDeckType.STARTING]
  if not deckData then done() return end
  local pos = shopMat.positionToWorld(deckData.pos):setAt("y", 2.5)

  local model = buildDeckModel(collectEntries(BagType.STARTING_CARDS))
  if not model.base then done() return end

  for i in pairs(collectEntries(BagType.STARTING_CARDS)) do
    consumeComponent(BagType.STARTING_CARDS, i)
  end

  mergeDeckStack(BagType.STARTING_CARDS, model, pos, {0, 180, 180}, function()
    registerDeck(pos, ShopDeckType.STARTING, function(obj)
      SHOP_MAT_DATA.decks[ShopDeckType.STARTING].guid = obj.getGUID()
      SHOP_MAT_DATA.decks[ShopDeckType.STARTING].obj  = obj
      gameData.deckGuids[ShopDeckType.STARTING]        = obj.getGUID()
    end)
    done()
  end)
end

function addConditionMat2()
  local matData = CONDITION_MAT_DATA[2]
  if not matData or not matData.guid then return end
  local mat = matData.obj
  if not mat then return end
  local pos = mat.getPosition()
  mat.setPosition(Vector(pos.x, 2, pos.z))
end

local function placeConditionCards(done)
  local entries = collectEntries(BagType.CONDITION_CARDS)

  local groups    = {}
  local typeOrder = {}
  for i, entry in pairs(entries) do
    local t = entry.memo and string.lower(entry.memo.type or "") or ""
    for _, matData in ipairs(CONDITION_MAT_DATA) do
      if matData.obj and matData.deck[t] then
        if not groups[t] then
          groups[t] = {
            pos     = matData.obj.positionToWorld(matData.deck[t]):setAt("y", 3),
            keys    = {},
            entries = {},
          }
          table.insert(typeOrder, t)
        end
        table.insert(groups[t].keys, i)
        table.insert(groups[t].entries, entry)
        break
      end
    end
  end

  if #typeOrder == 0 then done() return end

  local remaining = #typeOrder
  for _, t in ipairs(typeOrder) do
    local group = groups[t]
    for _, k in ipairs(group.keys) do
      consumeComponent(BagType.CONDITION_CARDS, k)
    end
    local model = buildDeckModel(group.entries)
    if not model.base then
      remaining = remaining - 1
      if remaining == 0 then done() end
    else
      mergeDeckStack(BagType.CONDITION_CARDS, model, group.pos, {0, 180, 180}, function()
        registerDeck(group.pos, t ~= "" and t or nil, function(obj)
          gameData.deckGuids["condition_" .. t] = obj.getGUID()
        end)
        remaining = remaining - 1
        if remaining == 0 then done() end
      end)
    end
  end
end

