-- ╭──────────────────────────────────────────────╮
-- │            STEP: Take Codex                  │
-- ╰──────────────────────────────────────────────╯
--
-- Draws a codex card (by number) from the archive on the location mat and
-- attaches it to the codex mat at the next free codex snap point.

local function findCodexCardOnSnapPoints(locationMat, number)
  for _, snp in ipairs(locationMat.getSnapPoints()) do
    if snp.tags then
      for _, tag in ipairs(snp.tags) do
        if tag == "codex_mat" then
          local worldPos = locationMat.positionToWorld(snp.position)
          local objs = upCast_pos(worldPos, 0.5)
          for _, o in ipairs(objs) do
            if o.type == "Tile" then
              for _, att in ipairs(o.getAttachments()) do
                local obj = getObjectFromGUID(att.guid)
                if obj then
                  local data = parseJson(obj.memo)
                  if data and data.number == number then
                    return obj
                  end
                end
              end
            end
          end
          break
        end
      end
    end
  end
end

function processStepTakeCodexFromArchive(step, context, onDone)
  if not step.number then
    log("[takeCodexFromArchive] number is nil")
    return
  end

  local sourceMat = findBoardByQuery({{
    field = "type",
    op    = "eq",
    value = "locationMat"
  }})
  if not sourceMat then
    log("[takeCodexFromArchive] locationMat not found")
    return
  end

  local archive = findDeckOnBoardByType(sourceMat, "archive")
  if not archive then
    log("[takeCodexFromArchive] archive not found")
    return
  end

  local codexMat = context.codexMat
  if not codexMat then
    log("[takeCodexFromArchive] codexMat is nil")
    return
  end

  local freePos = findNextFreeCodexSnapPos(sourceMat)
  if not freePos then
    log("[takeCodexFromArchive] no free codex snap")
    return
  end

  local card = takeCardByQuery(archive, {{
    field = "number",
    op    = "eq",
    value = step.number
  }})

  if not card then
    log("[takeCodexFromArchive] card with number " .. step.number .. " not found")
    return
  end

  if step.rotationFromCodex then
    local refCard = findCodexCardOnSnapPoints(sourceMat, step.rotationFromCodex)
    if refCard then
      card.setRotation(refCard.getRotation())
    end
  end

  card.setPositionSmooth(freePos:setAt("y", 3))
  runAfterRest(card, function(c)
    attachCodexCard(c, freePos)

    if context.removeAfterUse and not step.destructSelf then
      codexMat.call("onActionSuccess", context.removeAfterUse)
    end

    if step.destructSelf then
      removeCodexAttachment(codexMat)
      codexMat.destruct()
    end

    Wait.time(function()
      if onDone then onDone() end
    end, 0.2)
  end)
end
