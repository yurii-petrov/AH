-- ╭──────────────────────────────────────────────╮
-- │            STEP: Take Codex                  │
-- ╰──────────────────────────────────────────────╯
--
-- Draws a codex card (by number) from the archive on the location mat and
-- attaches it to the codex mat at the next free codex snap point.

local function attachCodexCardAtBottom(codexMat, card, rotation)
  local CARD_OFFSET = 0.11
  local height      = codexMat.getBounds().size.y
  local matPos      = codexMat.getPosition()
  local existing    = #codexMat.getAttachments()

  card.setRotation(rotation)
  card.setPosition({
    x = matPos.x,
    y = matPos.y - height - CARD_OFFSET - existing * 0.05,
    z = matPos.z
  })
  card.interactable = false
  codexMat.addAttachment(card)
end

local function findCodexMatOnSnapPoints(locationMat, number)
  for _, snp in ipairs(locationMat.getSnapPoints()) do
    if snp.tags then
      for _, tag in ipairs(snp.tags) do
        if tag == "codex_mat" then
          local worldPos = locationMat.positionToWorld(snp.position)
          local objs = upCast_pos(worldPos, 1)
          for _, o in ipairs(objs) do
            if o.type == "Tile" then
              for _, att in ipairs(o.getAttachments()) do
                local data = parseJson(att.memo)
                if data and string.lower(tostring(data.type or "")) == "codex" and data.number == number then
                  return o
                end
              end
            end
          end
        end
      end
    end
  end
end

function processStepTakeCodexFromArchive(step, context, onDone)
  if not step.number then
    log("[takeCodexFromArchive] number is nil")
    return
  end

  local sourceMat = findBoardByQuery({{
    field = "type",
    op    = "eq",
    value = "locationMat"
  }})
  if not sourceMat then
    log("[takeCodexFromArchive] locationMat not found")
    return
  end

  local archive = findDeckOnBoardByType(sourceMat, "archive")
  if not archive then
    log("[takeCodexFromArchive] archive not found")
    return
  end

  local codexMat = context.codexMat
  if not codexMat then
    log("[takeCodexFromArchive] codexMat is nil")
    return
  end

  local freePos = findNextFreeCodexSnapPos(sourceMat)
  local stackOnCurrent = false
  if not freePos then
    stackOnCurrent = true
    freePos = codexMat.getPosition():setAt("y", 3)
    log("[takeCodexFromArchive] no free codex snap, stacking on current codex")
  end

  local rotation = { 0, 180, 0 }
  if step.rotationFromCodex then
    local refMat = findCodexMatOnSnapPoints(sourceMat, step.rotationFromCodex)
    if refMat then
      rotation = refMat.is_face_down and {0, 180, 180} or {0, 180, 0}
      log("[takeCodexFromArchive] refMat (codex "..step.rotationFromCodex..") rotation: "..serpent.tts(rotation))
    else
      log("[takeCodexFromArchive] refMat for codex "..step.rotationFromCodex.." not found")
    end
  end

  if step.faceFromCodex then
    local refMat = findCodexMatOnSnapPoints(sourceMat, step.faceFromCodex)
    if refMat then
      rotation = refMat.is_face_down and {0, 180, 180} or {0, 180, 0}
      log("[takeCodexFromArchive] faceFromCodex "..step.faceFromCodex.." is "..(refMat.is_face_down and "face down" or "face up"))
    else
      log("[takeCodexFromArchive] faceFromCodex "..step.faceFromCodex.." not found, defaulting face down")
    end
  elseif step.face_down then
    rotation = step.face_down and {0, 180, 180} or {0, 180, 0}
  end

  local card = takeCardByQuery(archive, {{
    field = "number",
    op    = "eq",
    value = step.number
  }}, {
    position = freePos:setAt("y", 3),
    rotation = rotation,
    smooth   = true
  })

  if not card then
    log("[takeCodexFromArchive] card with number " .. step.number .. " not found")
    return
  end
  runAfterRest(card, function(c)
    -- log("[takeCodexFromArchive] codex "..step.number.." rotation: "..serpent.tts(c.getRotation()))
    if stackOnCurrent then
      attachCodexCardAtBottom(codexMat, c, rotation)
    else
      attachCodexCard(c, freePos, rotation)
    end

    if step.destructSelf then
      context.removeAfterUse = nil
      removeCodexAttachment(codexMat)
      codexMat.destruct()
    end

    Wait.time(function()
      if onDone then onDone() end
    end, 0.2)
  end)
end
