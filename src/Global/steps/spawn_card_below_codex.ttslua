local DEFAULT_OFFSET = { x = 0, y = 0.5, z = 1.7 }

local ITEM_MAT_TYPES = { item = true, spell = true, ally = true, special = true }

local function shouldAttachItemMat(cardData)
  if not cardData then return false end
  if cardData.hp == nil and cardData.sp == nil then return false end
  for t in pairs(cardTypes(cardData)) do
    if ITEM_MAT_TYPES[t] then return true end
  end
  return false
end

function processStepSpawnCardBelowCodex(step, context, onDone)
  if not step.card or not step.card.query then
    log("[spawnCardBelowCodex] card.query is nil")
    if onDone then onDone() end
    return
  end

  local codexMat = context and context.codexMat
  if not codexMat then
    log("[spawnCardBelowCodex] codexMat is nil")
    if onDone then onDone() end
    return
  end

  local board = findBoardByQuery(step.board and step.board.query)
  if not board then
    log("[spawnCardBelowCodex] source board not found")
    if onDone then onDone() end
    return
  end

  local deck = findDeckOnBoardByType(board, step.deck)
  if not deck then
    log("[spawnCardBelowCodex] deck '" .. tostring(step.deck) .. "' not found on board")
    if onDone then onDone() end
    return
  end

  local offset = step.offset or DEFAULT_OFFSET
  local spawnPos = codexMat.positionToWorld({ offset.x, offset.y, offset.z }):setAt("y", 3)

  for _, o in ipairs(downCast_pos(spawnPos, 2)) do
    if (o.type == "Card" or o.type == "Deck" or o.type == "Tile")
       and not o.getLock() and o ~= codexMat then
      o.setPosition(codexMat.positionToWorld({ offset.x, offset.y, offset.z + 1 }):setAt("y", 3))
      break
    end
  end

  local rotation = step.face_down and { 0, 180, 180 } or { 0, 180, 0 }

  local card = takeCardByQuery(deck, step.card.query, {
    position = spawnPos,
    rotation = rotation,
    smooth   = true
  })

  if not card then
    log("[spawnCardBelowCodex] card not found in deck '" .. tostring(step.deck) .. "'")
    if onDone then onDone() end
    return
  end

  if card == deck then
    card.setRotation(rotation)
    card.setPositionSmooth(spawnPos)
  end

  local cardData = parseJson(card.memo)

  if cardIsType(cardData, "monster") then
    card.setPositionSmooth(spawnPos)
    Wait.time(function()
      spawnMonster(spawnPos, card)
      if onDone then onDone() end
    end, 0.5)
    return
  end

  if step.itemMat == false or not shouldAttachItemMat(cardData) then
    if onDone then onDone() end
    return
  end

  runAfterRest(card, function(c)
    local targetPos = c.getPosition():setAt("y", 2.21)
    attachItemToItemsMat(c, cardData, targetPos, itemMatBagId)
    if onDone then onDone() end
  end)
end
