
function processStepPlaceCodexOnEncounterDeck(step, context, onDone)
  local locationMat = findBoardByQuery({{
    field = "type",
    op    = "eq",
    value = "locationMat"
  }})
  if not locationMat then
    log("[placeCodexOnEncounterDeck] locationMat not found")
    if onDone then onDone() end
    return
  end

  local sourceDeckType = step.sourceDeck or "archive"
  local archive = findDeckOnBoardByType(locationMat, sourceDeckType)
  if not archive then
    log("[placeCodexOnEncounterDeck] source deck '" .. sourceDeckType .. "' not found")
    if onDone then onDone() end
    return
  end

  local number = step.number
  local neighborhood = step.neighborhood
  if not number or not neighborhood then
    log("[placeCodexOnEncounterDeck] number or neighborhood is nil")
    if onDone then onDone() end
    return
  end

  local encounterDeck = getDeckFromScenarioMat("encounter", neighborhood)
  if not encounterDeck then
    log("[placeCodexOnEncounterDeck] encounter deck not found for: " .. tostring(neighborhood))
    if onDone then onDone() end
    return
  end

  local rotation = encounterDeck.getRotation()
  local deckPos  = encounterDeck.getPosition()

  local card = takeCardByQuery(archive, {{
    field = "number",
    op    = "eq",
    value = number
  }}, {
    position = deckPos:setAt("y", 3),
    rotation = rotation,
    smooth   = false
  })

  if not card then
    log("[placeCodexOnEncounterDeck] card " .. tostring(number) .. " not found")
    if onDone then onDone() end
    return
  end

  card.setRotation(rotation)
  card.setPosition(deckPos:setAt("y", 3))
  encounterDeck.putObject(card)

  if onDone then onDone() end
end
