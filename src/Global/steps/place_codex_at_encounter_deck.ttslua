-- ╭──────────────────────────────────────────────╮
-- │     STEP: placeCodexAtEncounterDeck          │
-- ╰──────────────────────────────────────────────╯
--
-- Takes a codex card from the archive by number and places it face-up
-- next to the encounter deck for the named neighborhood on the scenario mat.
--
-- Two call modes:
--   Direct:  { "type": "placeCodexAtEncounterDeck", "number": 32, "neighborhood": "Rivertown" }
--   Map:     { "type": "placeCodexAtEncounterDeck",
--              "map": [ {"number":32,"neighborhood":"Rivertown"},
--                       {"number":33,"neighborhood":"Downtown"}, ... ] }
-- In map mode the first entry whose card is still in the source deck is used.
-- Optional: "sourceDeck": "codexDeck"  (default: "archive")

local CARD_SIDE_OFFSET = 0.7

function processStepPlaceCodexAtEncounterDeck(step, context, onDone)
  local locationMat = findBoardByQuery({{
    field = "type",
    op    = "eq",
    value = "locationMat"
  }})
  if not locationMat then
    log("[placeCodexAtEncounterDeck] locationMat not found")
    if onDone then onDone() end
    return
  end

  local sourceDeckType = (step.sourceDeck) or "archive"
  local archive = findDeckOnBoardByType(locationMat, sourceDeckType)
  if not archive then
    log("[placeCodexAtEncounterDeck] source deck '" .. sourceDeckType .. "' not found")
    if onDone then onDone() end
    return
  end

  local neighborhood
  local card

  if step.map then
    for _, entry in ipairs(step.map) do
      local candidate = takeCardByQuery(archive, {{
        field = "number",
        op    = "eq",
        value = entry.number
      }})
      if candidate then
        card         = candidate
        neighborhood = entry.neighborhood
        break
      end
    end
    if not card then
      log("[placeCodexAtEncounterDeck] no matching card found in archive")
      if onDone then onDone() end
      return
    end
  else
    local number = step.number
    neighborhood = step.neighborhood
    if not number or not neighborhood then
      log("[placeCodexAtEncounterDeck] number or neighborhood is nil")
      if onDone then onDone() end
      return
    end
    card = takeCardByQuery(archive, {{
      field = "number",
      op    = "eq",
      value = number
    }}, { smooth = true })
    if not card then
      log("[placeCodexAtEncounterDeck] card " .. tostring(number) .. " not found")
      if onDone then onDone() end
      return
    end
  end

  local encounterDeck = getDeckFromScenarioMat("encounter", neighborhood)
  if not encounterDeck then
    log("[placeCodexAtEncounterDeck] encounter deck not found for: " .. tostring(neighborhood))
    if onDone then onDone() end
    return
  end

  local deckPos = encounterDeck.getPosition()
  card.setRotation({ 0, 180, 0 })
  card.setPositionSmooth(Vector(deckPos.x, deckPos.y + 0.3, deckPos.z + CARD_SIDE_OFFSET))

  if onDone then onDone() end
end
