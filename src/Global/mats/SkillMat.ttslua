serpent = require("util/serpent")

local DEBUFF_MIN = -1
local DEBUFF_MAX = 1
local DEBUFF_FONT_SIZE = "110"

local DEBUFF_ICON_BY_ID = {
	debuff_lore         = '',
	debuff_influence     = '',
	debuff_observatione  = '',
	debuff_strength      = '',
	debuff_will          = '',
}

local data = {
	hp = 0,
	maxHp = nil,
	sp = 0,
	maxSp = nil,
	debuffValue = 0,
	debuffId = nil,
	showFront = false,
	mode = 1,
  }

local function baseSkillId(id)
	local last = id:sub(-1)
	if last == "1" or last == "2" then
		return id:sub(1, -2)
	end
	return id
end

function debuff(player, alt_click, id)
	local baseId = baseSkillId(id)
	local skillId = (baseId == "debuff_return") and data.debuffId or baseId
	if not skillId then return end

	local newValue
	if data.mode == 2 then
		newValue = (data.debuffValue == -1) and 0 or -1
	elseif data.mode == 3 then
		newValue = (data.debuffValue == 1) and 0 or 1
	else
		local delta = (alt_click == "-2") and -1 or 1
		newValue = (data.debuffValue or 0) + delta
		if newValue > DEBUFF_MAX then newValue = DEBUFF_MAX end
		if newValue < DEBUFF_MIN then newValue = DEBUFF_MIN end
	end

	if newValue == 0 then
		data.debuffValue = 0
		data.debuffId = nil
	else
		data.debuffValue = newValue
		data.debuffId = skillId
	end

	refreshVisibility()
end

local DEBUFF_ICONS = {
	{ id = "debuff_lore",         textColor = "#805d9b", position = "-440 -40 0" },
	{ id = "debuff_influence",    textColor = "#ff6f38", position = "-210 -40 0" },
	{ id = "debuff_observatione", textColor = "#467e42", position = "50 -40 0"   },
	{ id = "debuff_strength",     textColor = "#da4d38", position = "280 -40 0"  },
	{ id = "debuff_will",         textColor = "#667db6", position = "460 -40 0"  },
}

local SKILL_TOGGLE_UNSELECTED_COLOR = "#5a5a5a"

local function skillIdFromDebuffId(debuffId)
	return debuffId:gsub("^debuff_", "")
end

local SKILL_TOGGLE_COLOR_BY_ID = {}
for _, def in ipairs(DEBUFF_ICONS) do
	SKILL_TOGGLE_COLOR_BY_ID[skillIdFromDebuffId(def.id)] = def.textColor
end

local function isSkillSelected(skillId)
	if data.mode == 5 then return true end
	return data.selectedSkills and data.selectedSkills[skillId]
end

local function getSelectedSkills()
	local active = data.mode == 4 or data.mode == 5
	local result = {}
	for _, def in ipairs(DEBUFF_ICONS) do
		local skillId = skillIdFromDebuffId(def.id)
		result[skillId] = active and isSkillSelected(skillId) or false
	end
	return result
end

local function downCast(obj, dist, offset, multi)
	if obj == nil then return end
	dist = dist or 1
	offset = offset or 0
	multi = multi or 1
	local oPos = obj.getPosition()
	local oBounds = obj.getBoundsNormalized()
	local oRot = obj.getRotation()
	local hits = Physics.cast({
		origin = {oPos[1], oPos[2] - dist / 2 - oBounds.size.y / 2 - offset, oPos[3]},
		direction = {0, 1, 0},
		type = 3,
		size = {oBounds.size.x * multi, dist, oBounds.size.z * multi},
		orientation = {oRot[1], oRot[2], oRot[3]},
		max_distance = 0,
	})
	local hitObjects = {}
	for _, v in pairs(hits) do
		if v.hit_object ~= obj then
			table.insert(hitObjects, v.hit_object)
		end
	end
	return hitObjects
end

local function downCast_pos(worldPos, dist)
	local hits = Physics.cast({
		origin = { worldPos.x, worldPos.y - dist / 2, worldPos.z },
		direction = { 0, -1, 0 },
		type = 3,
		size = { 1, dist, 1 },
		max_distance = 0,
	})
	local result = {}
	for _, v in ipairs(hits) do
		table.insert(result, v.hit_object)
	end
	return result
end

local function makeSkillToggleButton(def, suffix)
	local skillId = skillIdFromDebuffId(def.id)
	local selected = isSkillSelected(skillId)
	return {
		tag = "button",
		attributes = {
			id = "skill_" .. skillId .. suffix,
			onClick = "skillToggle",
			width = "200",
			height = "280",
			position = def.position,
			fontSize = DEBUFF_FONT_SIZE,
			font = "Fonts/AHRDIcons",
			textColor = selected and def.textColor or SKILL_TOGGLE_UNSELECTED_COLOR,
			color = "clear",
			text = DEBUFF_ICON_BY_ID[def.id],
		}
	}
end

local function updateSkillToggleColors()
	for _, def in ipairs(DEBUFF_ICONS) do
		local skillId = skillIdFromDebuffId(def.id)
		local color = isSkillSelected(skillId) and SKILL_TOGGLE_COLOR_BY_ID[skillId] or SKILL_TOGGLE_UNSELECTED_COLOR
		self.UI.setAttribute("skill_" .. skillId .. "1", "textColor", color)
		self.UI.setAttribute("skill_" .. skillId .. "2", "textColor", color)
	end
end

local function makeSkillToggleGroup(suffix, position, rotation)
	local buttons = {}
	for _, def in ipairs(DEBUFF_ICONS) do
		table.insert(buttons, makeSkillToggleButton(def, suffix))
	end
	return {
		tag = "panel",
		attributes = { id = "skill_toggle_buttons" .. suffix, active = "false", width = "1200", height = "280", scale = "0.1 0.1 0", position = position, rotation = rotation },
		children = buttons,
	}
end

local SKILL_COUNTER_ICON_Y_OFFSET = 60

local function shiftY(position, delta)
	local x, y, z = position:match("^(%S+)%s+(%S+)%s+(%S+)$")
	if not x then return position end
	return x .. " " .. tostring(tonumber(y) + delta) .. " " .. z
end

local function skillCounterValue(skillId)
	return (data.skillCounters and data.skillCounters[skillId]) or 0
end

local function makeSkillCounterButton(def, suffix)
	local skillId = skillIdFromDebuffId(def.id)
	return {
		tag = "button",
		attributes = {
			id = "skillcnt_" .. skillId .. suffix,
			onClick = "skillCounterClick",
			width = "200",
			height = "280",
			position = shiftY(def.position, SKILL_COUNTER_ICON_Y_OFFSET),
			fontSize = DEBUFF_FONT_SIZE,
			font = "Fonts/AHRDIcons",
			textColor = def.textColor,
			color = "clear",
			text = DEBUFF_ICON_BY_ID[def.id],
		}
	}
end

local SKILL_COUNTER_TEXT_Y_OFFSET = -80

local function makeSkillCounterText(def, suffix)
	local skillId = skillIdFromDebuffId(def.id)
	return {
		tag = "text",
		attributes = {
			id = "skillcnt_txt_" .. skillId .. suffix,
			position = shiftY(def.position, SKILL_COUNTER_TEXT_Y_OFFSET),
			fontSize = "160",
			fontStyle = "Bold",
			font = "Fonts/AdonisC",
			color = "#fff5e2",
			text = tostring(skillCounterValue(skillId)),
		}
	}
end

local function makeSkillCounterGroup(suffix, position, rotation)
	local children = {}
	for _, def in ipairs(DEBUFF_ICONS) do
		table.insert(children, makeSkillCounterButton(def, suffix))
		table.insert(children, makeSkillCounterText(def, suffix))
	end
	return {
		tag = "panel",
		attributes = { id = "skill_counter_buttons" .. suffix, active = "false", width = "1200", height = "360", scale = "0.1 0.1 0", position = position, rotation = rotation },
		children = children,
	}
end

local function mirrorX(position)
	local x, rest = position:match("^(%S+)%s+(.+)$")
	if not x then return position end
	return tostring(-tonumber(x)) .. " " .. rest
end

local function makeDebuffButton(def, suffix)
	return {
		tag = "button",
		attributes = {
			id = def.id .. suffix,
			onClick = "debuff",
			width = "200",
			height = "280",
			position = def.position,
			fontSize = DEBUFF_FONT_SIZE,
			font = "Fonts/AHRDIcons",
			textColor = def.textColor,
			color = "clear",
			text = DEBUFF_ICON_BY_ID[def.id],
		}
	}
end

local function makeDebuffGroup(suffix, position, rotation)
	local debuffButtons = {}
	for _, def in ipairs(DEBUFF_ICONS) do
		table.insert(debuffButtons, makeDebuffButton(def, suffix))
	end

	return {
		{
			tag = "panel",
			attributes = { id = "debuff_buttons" .. suffix, active = "true", width = "1200", height = "280", scale = "0.1 0.1 0", position = position, rotation = rotation },
			children = debuffButtons,
		},
		{
			tag = "panel",
			attributes = { id = "debuff_display" .. suffix, active = "false", width = "1200", height = "280", scale = "0.1 0.1 0", position = position, rotation = rotation },
			children = {
				{ tag = "button", attributes = { id = "debuff_return" .. suffix, onClick = "debuff", width = "1000", height = "280", position = "0 -40 0", color = "clear", text = "" } },
				{ tag = "text", attributes = { id = "debuff_value" .. suffix, position = "-400 -30 0", fontSize = "220", fontStyle = "Bold", font = "Fonts/AdonisC", color = "#fff5e2", text = "" } },
				{ tag = "text", attributes = { id = "debuff_icon" .. suffix, position = "300 -45 0", fontSize = "280", font = "Fonts/AHRDIcons", color = "#805d9b", text = "" } },
			}
		},
	}
end

local function makeCounterPanel(id, active, position, onClick, textColor, padding, text, txtId, txtPosition, txtLabel, rotation)
	return {
		tag = "panel",
		attributes = { id = id, active = active, width = "500", height = "300", scale = "0.1 0.1 0", position = position, rotation = rotation },
		children = {
			{ tag = "button", attributes = {
					id = id .. "_btn",
					onClick = onClick,
					width = "500",
					height = "300",
					position = "0 -40 0",
					padding = padding,
					fontSize = "290",
					fontStyle = "Bold",
					font = "Fonts/AdonisC",
					textColor = textColor,
					color = "clear",
					text = text,
				}
			},
			{ tag = "text", attributes = {
					id = txtId,
					position = txtPosition,
					fontSize = "70",
					fontStyle = "Bold",
					font = "Fonts/AdonisC",
					color = "#fff5e2",
					text = txtLabel,
				}
			},
		}
	}
end

local function makeClsPanel(id, position, padding, rotation)
	return {
		tag = "panel",
		attributes = { id = id, active = "false", width = "500", height = "300", scale = "0.1 0.1 0", position = position, rotation = rotation },
		children = {
			{ tag = "button", attributes = {
					onClick = "ItemMatDestruct",
					width = "500",
					height = "300",
					position = "0 -40 0",
					padding = padding,
					fontSize = "290",
					fontStyle = "Bold",
					font = "Fonts/AdonisC",
					textColor = "#e9543b",
					color = "clear",
					text = "X",
				}
			},
		}
	}
end

local function buildUI()
	local debuffGroup1 = makeDebuffGroup("1", "0 82 -15", "0 0 180")
	local debuffGroup2 = makeDebuffGroup("2", mirrorX("0 82 10"), "0 180 180")

	local xml = {}
	for _, e in ipairs(debuffGroup1) do table.insert(xml, e) end
	for _, e in ipairs(debuffGroup2) do table.insert(xml, e) end

	table.insert(xml, makeSkillToggleGroup("1", "0 82 -15", "0 0 180"))
	table.insert(xml, makeSkillToggleGroup("2", mirrorX("0 82 10"), "0 180 180"))

	table.insert(xml, makeSkillCounterGroup("1", "0 82 -15", "0 0 180"))
	table.insert(xml, makeSkillCounterGroup("2", mirrorX("0 82 10"), "0 180 180"))

	table.insert(xml, makeCounterPanel("damage1", "false", "30 85 -11", "damage", "#e9543b", "0 300 10 0", "0", "damage_txt1", "150 78 0", "ПОРАНЕННЯ", "0 0 180"))
	table.insert(xml, makeClsPanel("damage_cls1", "30 85 -11", "0 300 10 0", "0 0 180"))
	table.insert(xml, makeCounterPanel("horror1", "false", "-30 85 -11", "horror", "#485cb3", "300 0 10 0", "0", "horror_txt1", "-26 -93 -11", "ЖАХ", "0 0 180"))
	table.insert(xml, makeClsPanel("horror_cls1", "-30 85 -11", "300 0 10 0", "0 0 180"))

	table.insert(xml, makeCounterPanel("damage2", "false", mirrorX("30 85 -11"), "damage", "#e9543b", "0 300 10 0", "0", "damage_txt2", "150 78 0", "ПОРАНЕННЯ", "0 180 180"))
	table.insert(xml, makeClsPanel("damage_cls2", mirrorX("30 85 -11"), "0 300 10 0", "0 180 180"))
	table.insert(xml, makeCounterPanel("horror2", "false", mirrorX("-30 85 -11"), "horror", "#485cb3", "300 0 10 0", "0", "horror_txt2", "-26 -93 -11", "ЖАХ", "0 180 180"))
	table.insert(xml, makeClsPanel("horror_cls2", mirrorX("-30 85 -11"), "300 0 10 0", "0 180 180"))

	self.UI.setXmlTable(xml)
end

  function onLoad(savedData)
	local sData = parseJson(savedData)
	if sData then
	  data = sData
	end

	buildUI()
	Wait.time(refreshVisibility, 0.5, -1)
  end

  function onSave()
	local saveData = JSON.encode(data)
	return saveData
  end

function refreshVisibility()
	local atts = self.getAttachments()
	local card = atts and atts[1]
	local cardData = card and parseJson(card.memo)
	local reversed = (cardData and cardData.reversed) or false
	local showFront = self.is_face_down and reversed
	data.showFront = showFront
	data.mode = (cardData and cardData.skillMatMode) or data.mode or 1

	local cardGuid = card and card.guid
	if cardGuid ~= data.lastCardGuid then
		data.lastCardGuid = cardGuid
		data.selectedSkills = {}
		data.skillCounters = {}
	end

	local skillToggleActive = data.mode == 4 or data.mode == 5
	local skillCounterActive = data.mode == 6
	local debuffActive = (not skillToggleActive) and (not skillCounterActive) and data.debuffValue and data.debuffValue ~= 0
	self.UI.setAttribute('debuff_buttons1', 'active', tostring((not showFront) and not debuffActive and not skillToggleActive and not skillCounterActive))
	self.UI.setAttribute('debuff_display1', 'active', tostring((not showFront) and debuffActive))
	self.UI.setAttribute('debuff_buttons2', 'active', tostring(showFront and not debuffActive and not skillToggleActive and not skillCounterActive))
	self.UI.setAttribute('debuff_display2', 'active', tostring(showFront and debuffActive))

	self.UI.setAttribute('skill_toggle_buttons1', 'active', tostring((not showFront) and skillToggleActive))
	self.UI.setAttribute('skill_toggle_buttons2', 'active', tostring(showFront and skillToggleActive))
	if skillToggleActive then
		updateSkillToggleColors()
	end

	self.UI.setAttribute('skill_counter_buttons1', 'active', tostring((not showFront) and skillCounterActive))
	self.UI.setAttribute('skill_counter_buttons2', 'active', tostring(showFront and skillCounterActive))
	if skillCounterActive then
		updateSkillCounterTexts()
	end

	if debuffActive then
		local debuff_icon = DEBUFF_ICON_BY_ID[data.debuffId]
		local debuff_color = self.UI.getAttribute(data.debuffId .. "1", 'textColor')
		local debuff_text = (data.debuffValue > 0 and "+" or "") .. tostring(data.debuffValue)
		self.UI.setAttribute('debuff_icon1', 'text', debuff_icon)
		self.UI.setAttribute('debuff_icon1', 'color', debuff_color)
		self.UI.setAttribute('debuff_value1', 'text', debuff_text)
		self.UI.setAttribute('debuff_icon2', 'text', debuff_icon)
		self.UI.setAttribute('debuff_icon2', 'color', debuff_color)
		self.UI.setAttribute('debuff_value2', 'text', debuff_text)
	end

	local hpEnabled = data.maxHp ~= nil
	local spEnabled = data.maxSp ~= nil
	local hpMaxed = hpEnabled and data.hp == data.maxHp
	local spMaxed = spEnabled and data.sp == data.maxSp

	self.UI.setAttribute('horror1', 'active', tostring((not showFront) and hpEnabled and not hpMaxed))
	self.UI.setAttribute('horror_cls1', 'active', tostring((not showFront) and hpMaxed))
	self.UI.setAttribute('damage1', 'active', tostring((not showFront) and spEnabled and not spMaxed))
	self.UI.setAttribute('damage_cls1', 'active', tostring((not showFront) and spMaxed))

	self.UI.setAttribute('horror2', 'active', tostring(showFront and hpEnabled and not hpMaxed))
	self.UI.setAttribute('horror_cls2', 'active', tostring(showFront and hpMaxed))
	self.UI.setAttribute('damage2', 'active', tostring(showFront and spEnabled and not spMaxed))
	self.UI.setAttribute('damage_cls2', 'active', tostring(showFront and spMaxed))

	self.UI.setAttribute('damage1_btn', 'text', data.hp)
	self.UI.setAttribute('horror1_btn', 'text', data.sp)
	self.UI.setAttribute('damage2_btn', 'text', data.hp)
	self.UI.setAttribute('horror2_btn', 'text', data.sp)
end

function damage(player, alt_click, id)
	if alt_click == "-1" then
		if data.maxHp and data.hp < data.maxHp then data.hp = data.hp + 1 end
	elseif alt_click == "-2" then
		if data.hp > 0 then data.hp = data.hp - 1 end
	end
	refreshVisibility()
end

function horror(player, alt_click, id)
	if alt_click == "-1" then
		if data.maxSp and data.sp < data.maxSp then data.sp = data.sp + 1 end
	elseif alt_click == "-2" then
		if data.sp > 0 then data.sp = data.sp - 1 end
	end
	refreshVisibility()
end

function setData(d)
	data.hp = 0
	data.sp = 0
	data.maxHp = d.hp
	data.maxSp = d.sp
	data.unbreakable = d.unbreakable
	refreshVisibility()
end

function skillToggle(player, alt_click, id)
	if data.mode == 5 then return end

	local skillId = id:match("^skill_(%a+)%d$")
	if not skillId then return end

	data.selectedSkills = data.selectedSkills or {}
	local selected = not data.selectedSkills[skillId]
	data.selectedSkills[skillId] = selected

	local color = selected and SKILL_TOGGLE_COLOR_BY_ID[skillId] or SKILL_TOGGLE_UNSELECTED_COLOR
	self.UI.setAttribute("skill_" .. skillId .. "1", "textColor", color)
	self.UI.setAttribute("skill_" .. skillId .. "2", "textColor", color)

	applySkillMatBonus()
end

function updateSkillCounterTexts()
	for _, def in ipairs(DEBUFF_ICONS) do
		local skillId = skillIdFromDebuffId(def.id)
		local text = tostring(skillCounterValue(skillId))
		self.UI.setAttribute("skillcnt_txt_" .. skillId .. "1", "text", text)
		self.UI.setAttribute("skillcnt_txt_" .. skillId .. "2", "text", text)
	end
end

function skillCounterClick(player, alt_click, id)
	local skillId = id:match("^skillcnt_(%a+)%d$")
	if not skillId then return end

	data.skillCounters = data.skillCounters or {}
	local current = skillCounterValue(skillId)
	if alt_click == "-1" then
		current = current + 1
	elseif alt_click == "-2" then
		current = math.max(0, current - 1)
	end
	data.skillCounters[skillId] = current

	local text = tostring(current)
	self.UI.setAttribute("skillcnt_txt_" .. skillId .. "1", "text", text)
	self.UI.setAttribute("skillcnt_txt_" .. skillId .. "2", "text", text)
end

function applySkillMatBonus()
	local foundObjects = downCast(self, 10, nil, 1)
	local itemsMat = nil
	for _, obj in ipairs(foundObjects) do
		if obj.memo == "Items Mat" then
			itemsMat = obj
			break
		end
	end

	local investigatorMat = nil
	if itemsMat then
		local p = itemsMat.getPosition():setAt("z", -44)
		for _, obj in ipairs(downCast_pos(p, 0.1)) do
			if obj.memo == "Investigator Mat" then
				investigatorMat = obj
				break
			end
		end
	end

	local newGuid = investigatorMat and investigatorMat.guid or nil

	if data.appliedInvestigatorMatGuid and data.appliedInvestigatorMatGuid ~= newGuid then
		local oldMat = getObjectFromGUID(data.appliedInvestigatorMatGuid)
		if oldMat then
			oldMat.call("setSkillMatBonus", { matGuid = self.guid, skills = {} })
		end
	end

	if newGuid then
		investigatorMat.call("setSkillMatBonus", { matGuid = self.guid, skills = getSelectedSkills() })
	end

	data.appliedInvestigatorMatGuid = newGuid
end

function clearSkillMatBonus()
	if not data.appliedInvestigatorMatGuid then return end
	local mat = getObjectFromGUID(data.appliedInvestigatorMatGuid)
	if mat then
		mat.call("setSkillMatBonus", { matGuid = self.guid, skills = {} })
	end
	data.appliedInvestigatorMatGuid = nil
end

function ItemMatDestruct()
	Global.call("onItemMatDestruct", self)
end

function parseJson(memo)
  if not memo or type(memo) ~= "string" then
    return nil
  end

  local success, result = pcall(function()
    return JSON.decode(memo)
  end)

  if success then
    return result
  else
    return nil
  end
end
