end

function getRootXmlTable()
  return {
    languagesWindow(),
    phaseWindow(),
    helpWindow(),
    defaultsBlock(),
    mainMenuWindow(),
    chooseScenarioWindow(),
    chooseAddonsWindow(),
    restoreWindow(),
    buildInvestigatorsCollapsedPanel(),
    buildInvestigatorsWindow(),
  }
end
