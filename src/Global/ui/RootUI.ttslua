                        },
                      },
                      {
                        tag = "HorizontalLayout",
                        attributes = { id = "scenario_select_all_row", rectAlignment = "LowerCenter", offsetXY = "0 4", width = "400", height = "28", childAlignment = "MiddleCenter", childForceExpandWidth = "false", childForceExpandHeight = "false", spacing = "10" },
                        children = {
