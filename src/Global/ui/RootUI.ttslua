      {
        tag = "panel",
        attributes = { width = "437", height = "330", position = "233 133", rectAlignment = "MiddleCenter" },
        children = {
          {
            tag = "VerticalLayout",
            attributes = { contentSizeFitter = "vertical", rectAlignment = "UpperCenter", spacing = "15" },
