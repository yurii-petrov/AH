
local FONT = "Fonts/AdonisC"

local function imageButtonPanel(panelAttrs, button, image)
  return {
    tag = "panel",
    attributes = panelAttrs,
    children = { button, image },
  }
end

local function buildPlayerButtons()
  local buttons = {}
  for n = 1, 6 do
    local btnAttrs = {
      id = "players" .. n,
      onClick = "menuSelectPlayers",
      text = tostring(n),
      fontSize = "46",
    }
    if n == 2 then btnAttrs.color = "#ffffff22" end
    table.insert(buttons, imageButtonPanel(
      {},
      { tag = "Button", attributes = btnAttrs },
      { tag = "image", attributes = { image = "button_num" } }
    ))
  end
  return buttons
end

local function buildMainMenuActions()
  local defs = {
    { id = "MM_close",      onClick = "closeMenu" },
    { id = "MM_expansions", onClick = "onClickAddons" },
    { id = "MM_start_game", onClick = "startGame" },
  }
  local panels = {}
  for _, d in ipairs(defs) do
    table.insert(panels, imageButtonPanel(
      {},
      { tag = "Button", attributes = { id = d.id, onClick = d.onClick, text = "", color = "clear" } },
      { tag = "image", attributes = { image = "button_medium" } }
    ))
  end
  return panels
end

local SCENARIO_COUNT = 13

local function buildScenarioListPanels()
  local panels = {}
  for n = 1, SCENARIO_COUNT do
    local panelAttrs = { id = "scenario_panel" .. n, preferredHeight = "50" }
    if n == 1 then panelAttrs.color = "#ffffff22" end
    table.insert(panels, {
      tag = "panel",
      attributes = panelAttrs,
      children = {
        { tag = "button", attributes = { id = "scenario" .. n, onClick = "chooseScenario", onMouseEnter = "previewScenario" } },
        { tag = "text",   attributes = { id = "MM_scenario" .. n .. "_name_text", alignment = "MiddleCenter", text = "" } },
      },
    })
  end
  return panels
end

local ADDON_COUNT = 4

local function buildAddonPanels()
  local panels = {}
  for n = 1, ADDON_COUNT do
    local panelAttrs = { id = "addon_panel" .. n, preferredHeight = "50" }
    if n == 1 then panelAttrs.color = "#ffffff22" end
    table.insert(panels, {
      tag = "panel",
      attributes = panelAttrs,
      children = {
        { tag = "button", attributes = { id = "addon" .. n, onClick = "selectAddon", onMouseEnter = "previewAddon" } },
        { tag = "text",   attributes = { id = "MM_text_addon" .. n .. "_text", alignment = "MiddleCenter", text = "" } },
      },
    })
  end
  return panels
end

local function languagesWindow()
  return {
    tag = "panel",
    attributes = {
      id = "languages",
      width = "1000",
      height = "482",
      rectAligment = "middleCenter",
      allowDragging = "true",
      returnToOriginalPositionWhenReleased = "false",
    },
    children = {
      { tag = "image", attributes = { image = "languages", width = "1000", height = "482" } },
      { tag = "button", attributes = { id = "en", onClick = "clickOnEN", width = "350", height = "300", position = "-220 0 0", padding = "0 0 230 0", textColor = "#ffffff", font = FONT, fontStyle = "Bold", fontSize = "30", color = "clear", text = "ENGLISH" } },
      { tag = "button", attributes = { id = "ua", onClick = "clickOnUK", width = "350", height = "300", position = "220 0 0", padding = "0 0 230 0", textColor = "#ffffff", font = FONT, fontStyle = "Bold", fontSize = "30", color = "clear", text = "УКРАЇНСЬКА" } },
      {
        tag = "HorizontalLayout",
        attributes = { id = "direct_setup_row", position = "0 -155 0", width = "220", height = "28", childAlignment = "MiddleCenter", childForceExpandWidth = "false", childForceExpandHeight = "false", spacing = "10" },
        children = {
          { tag = "Text", attributes = { text = "Quick Setup", font = FONT, fontSize = "18", color = "#ffffff", width = "160", height = "28" } },
          { tag = "Toggle", attributes = { id = "direct_setup_toggle", onValueChanged = "onDirectSetupToggle", isOn = "false", width = "24", height = "24", color = "#ffffff", toggleColor = "#000000" } },
        },
      },
      { tag = "Text", attributes = { id = "direct_setup_note", position = "0 -192 0", width = "640", height = "40", font = FONT, fontSize = "14", color = "#ffffffaa", alignment = "MiddleCenter", text = "(use only with cache enabled, and after the mod was already opened once in normal mode)" } },
    },
  }
end

local function phaseWindow()
  local function phaseText(id, offsetXY, fontSize, active)
    local attrs = {
      id = id,
      offsetXY = offsetXY,
      font = FONT,
      fontSize = fontSize,
      color = "#ffffff",
      shadow = "#000000",
      shadowDistance = "1 1",
      outline = "#00000088",
      outlineSize = "2 2",
      text = "",
    }
    if active ~= nil then attrs.active = active end
    return { tag = "text", attributes = attrs }
  end

  return {
    tag = "panel",
    attributes = { id = "phase", active = "false", width = "200", height = "264", rectAlignment = "LowerRight", allowDragging = "true", returnToOriginalPositionWhenReleased = "false" },
    children = {
      { tag = "image", attributes = { id = "phase_img", image = "phase_action_image", width = "200", preserveAspect = "true", rectAlignment = "UpperCenter" } },
      phaseText("PB_phase_text", "0 45", "12"),
      phaseText("phase_text", "0 25", "16"),
      { tag = "button", attributes = { id = "phase_btn", onClick = "nextPhase", width = "200", height = "170", rectAlignment = "UpperCenter", color = "clear", tooltip = i18n.getStrById("phase_btn+tooltip"), tooltipPosition = "Left" } },
    },
  }
end

local function helpWindow()
  return {
    tag = "Panel",
    attributes = { id = "help_panel", visibility = "nobody", position = "0 0 -50", width = "700", height = "340", rectAlignment = "MiddleCenter", allowDragging = "true", returnToOriginalPositionWhenReleased = "false" },
    children = {
      { tag = "Image", attributes = { image = "help_bg", preserveAspect = "true", width = "700" } },
      {
        tag = "verticalLayout",
        attributes = { width = "650", height = "280" },
