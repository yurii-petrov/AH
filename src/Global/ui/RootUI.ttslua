        },
      },
      {
        tag = "panel",
        attributes = { width = "440", height = "92", position = "-233 -138" },
        children = {
          { tag = "Button", attributes = { id = "MM_change_scenario", onClick = "changeScenario", width = "440", height = "92", color = "clear", text = "" } },
          { tag = "image", attributes = { width = "440", height = "92", image = "button_large" } },
        },
      },
      { tag = "text", attributes = { id = "MM_player_numbers", childAlignment = "MiddleCenter", position = "515 -394", text = "", fontSize = "32", fontStyle = "bold" } },
      {
        tag = "HorizontalLayout",
