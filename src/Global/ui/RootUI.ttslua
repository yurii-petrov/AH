        },
      },
      { tag = "Button", attributes = { id = "close_help", text = "X", onClick = "hideHelp", width = "160", height = "160", position = "310 120 0", fontSize = "50", font = FONT, textColor = "#ffffff", color = "clear" } },
    },
  }
end

