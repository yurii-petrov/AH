  return {
    tag = "panel",
    attributes = {
      id            = "INV_collapse_alone",
      active        = "false",
      width         = "20",
      height        = "60",
      color         = "#000000ee",
      rectAlignment = "MiddleRight",
      offsetXY      = "0 0",
    },
    children = {
      {
        tag = "Button",
        attributes = {
          onClick   = "investigatorToggleCollapse",
          text      = "◀",
          padding   = "5 0",
          color     = "clear",
          minWidth  = "20",
          minHeight = "60",
          textColor = CHEVRON_COL,
