  return {
    tag = "HorizontalLayout",
    attributes = {
      id                                   = "investigators",
      active                               = "false",
      width                                = PANEL_W,
      color                                = PANEL_BG,
      rectAlignment                        = "MiddleRight",
      offsetXY                             = "0 0",
      padding                              = "0",
      spacing                              = "0",
      contentSizeFitter                    = "vertical",
      childAlignment                       = "MiddleCenter",
      childForceExpandWidth                = "false",
      childForceExpandHeight               = "true",
      allowDragging                        = "true",
      returnToOriginalPositionWhenReleased = "false",
    },
    children = {
      {
        tag = "Button",
        attributes = {
          id             = "INV_collapse",
          onClick        = "investigatorToggleCollapse",
          text           = "▶",
          padding        = "0 3 0 0",
          color          = "clear",
          minWidth       = "20",
          preferredWidth = "20",
          flexibleWidth  = "0",
          textColor      = CHEVRON_COL,
          font           = FONT,
          fontSize       = "22",
        },
      },
