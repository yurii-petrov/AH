
local FONT = "Fonts/AdonisC"

local MIN_INV          = 2
local MAX_INV          = 6
local DEFAULT_COUNT    = 2
local ACTIONS_PER_INV  = 2

local PANEL_W          = "310"
local ROW_H            = "44"
local ROW_SPACING      = "8"
local SECTION_SPACING  = "10"
local APPLY_H          = "30"
local PAD              = "10"
local ACTION_SIZE      = "34"
local AVATAR_SIZE      = "34"
local BORDER_W         = "2"

local INV_GOLD      = "#F2C230"
local INV_DARK      = "#141414"
local PANEL_BG      = "#000000bb"
local TEXT_COL      = "#ffffff"
local ENCOUNTER_CLR = "#1a6b1a"
local MYTHOS_CLR    = "#8b1a1a"
local PHASE_BTN_W   = "100"
local CHEVRON_COL   = "#666666"
local AVATAR_PLACEHOLDER = "investigator_portrait"

local SLOT_COLORS = { "#FFFFFF", "#FF3B30", "#34C759", "#3478F6", "#FFD60A", "#AF52DE" }

local function slotBorderColor(p)
  return SLOT_COLORS[p] or CHEVRON_COL
end

INV_STATE = {
  count          = DEFAULT_COUNT,
  applied        = false,
  snapshot       = nil,
  actions        = {},
  isLeaderAction = {},
  slotByName     = {},
  nameBySlot     = {},
  baseKeyBySlot  = {},
  phase          = 1,
  encounterDone  = {},
  mythosCount    = {},
  mythosActive   = nil,
}

local ACTIVATION_MEMOS = {
  ["Activation Token"]       = true,
  ["Leader Activation Token"] = true,
}

for p = 1, MAX_INV do
  INV_STATE.actions[p] = {}
  INV_STATE.isLeaderAction[p] = {}
  for a = 1, ACTIONS_PER_INV do
    INV_STATE.actions[p][a] = false
    INV_STATE.isLeaderAction[p][a] = false
  end
end

for p = 1, MAX_INV do
  INV_STATE.encounterDone[p] = false
  INV_STATE.mythosCount[p]   = 2
end

local function defaultInvestigatorName(p)
  return string.format(i18n.getStrById("INV_default_name_text"), p)
end

local COLLAPSE_W     = 20
local ROW_GAP        = 10
local NAME_MIN_CHARS = 4
local NAME_CHAR_PX   = 12
local PANEL_W_MAX    = 460

local RIGHT_BLOCK_W = math.max(2 * tonumber(ACTION_SIZE) + ROW_GAP, tonumber(PHASE_BTN_W))
local PANEL_FIXED_W = COLLAPSE_W + tonumber(PAD) * 2 + tonumber(AVATAR_SIZE) + ROW_GAP * 2 + RIGHT_BLOCK_W

local function utf8Length(s)
  local len = 0
  for i = 1, #s do
    local b = string.byte(s, i)
    if b < 0x80 or b >= 0xC0 then
      len = len + 1
    end
  end
  return len
end

local function firstWord(name)
  local spacePos = name:find(" ", 1, true)
  if spacePos then
    return name:sub(1, spacePos - 1)
  end
  return name
end

local function lastWord(name)
  local lastSpace = nil
  local searchFrom = 1
  while true do
    local pos = name:find(" ", searchFrom, true)
    if not pos then break end
    lastSpace = pos
    searchFrom = pos + 1
  end
  return lastSpace and name:sub(lastSpace + 1) or name
end

local LAST_WORD_NAMES = {
  Father_Mateo = true,
  Ashcan_Pete = true
}

local function shortDisplayName(name, baseKey)
  if baseKey and LAST_WORD_NAMES[baseKey] then
    return lastWord(name)
  end
  return firstWord(name)
end

local function displayedNameForSlot(slot)
  local full = INV_STATE.nameBySlot[slot]
  if full then return shortDisplayName(full, INV_STATE.baseKeyBySlot[slot]) end
  return defaultInvestigatorName(slot)
end

local function refreshPanelWidth()
  local maxLen = NAME_MIN_CHARS
  for p = 1, INV_STATE.count do
    local len = utf8Length(displayedNameForSlot(p))
    if len > maxLen then maxLen = len end
  end
  local w = PANEL_FIXED_W + maxLen * NAME_CHAR_PX
  if w > PANEL_W_MAX then w = PANEL_W_MAX end
  self.UI.setAttribute("investigators", "width", w)
end

local function mythosCountText(count)
  if count <= 0 then
    return i18n.getStrById("INV_mythos_zero")
  end
  return string.format(i18n.getStrById("INV_mythos"), count)
end

local LEADER_ACTION_NO  = "action_no"
local LEADER_ACTION_YES = "action_yes"
local ACTION_NO         = "action_no"
local ACTION_YES        = "action_yes"

local function actionImage(isLeader, spent)
  if isLeader then
    return spent and LEADER_ACTION_NO or LEADER_ACTION_YES
  else
    return spent and ACTION_NO or ACTION_YES
  end
end

local function actionId(p, a)
  return "INV_action_" .. p .. "_" .. a
end

local function refreshActionButton(p, a)
  local isLeader = INV_STATE.isLeaderAction[p][a]
  self.UI.setAttribute(actionId(p, a), "image", actionImage(isLeader, INV_STATE.actions[p][a]))
end

local function refreshAllActionColors()
  for p = 1, MAX_INV do
    for a = 1, ACTIONS_PER_INV do
      refreshActionButton(p, a)
    end
  end
end

local function setApplyPressed(pressed)
  self.UI.setAttribute("INV_apply_text", "text", i18n.getStrById(pressed and "INV_apply_restore_text" or "INV_apply_text"))
  self.UI.setAttribute("INV_apply_text", "color", pressed and INV_GOLD or "clear")
  self.UI.setAttribute("INV_apply_text", "textColor", pressed and INV_DARK or INV_GOLD)
end

local function saveActionsToGameData()
  gameData.invActions = {}
  for p = 1, INV_STATE.count do
    gameData.invActions[p] = {}
    for a = 1, ACTIONS_PER_INV do
      gameData.invActions[p][a] = INV_STATE.actions[p][a]
    end
  end
  gameData.invApplied = INV_STATE.applied
end

local function activationTokensOn(mat)
  local tokens = {}
  for _, o in ipairs(upCast(mat, 3, 0, 1) or {}) do
    if o.type == "Tile" and o.memo and ACTIVATION_MEMOS[o.memo] then
      tokens[#tokens + 1] = o
    end
  end
  table.sort(tokens, function(t1, t2)
    local a = mat.positionToLocal(t1.getPosition())
    local b = mat.positionToLocal(t2.getPosition())
    if math.abs(a.x - b.x) > 0.05 then return a.x > b.x end
    return a.z > b.z
  end)
  return tokens
end

local function matForSlot(slot)
  local p = TABLE_DATA.players[slot]
  return p and p.obj
end

local function colorForSlot(slot)
  local hand = getHandForSlot(slot)
  if not hand then return end
  local c = hand.getValue()
  return (c and c ~= "") and c or nil
end

local function slotForColor(color)
  for p = 1, MAX_INV do
    if TABLE_DATA.players[p] and colorForSlot(p) == color then
      return p
    end
  end
end

local function blockedByOwner(slot, player)
  local owner = colorForSlot(slot)
  local ownerPlayer = owner and Player[owner]
  if ownerPlayer and ownerPlayer.seated and ownerPlayer.steam_id ~= player.steam_id then
    local invName = INV_STATE.nameBySlot[slot] or defaultInvestigatorName(slot)
    local ownerName = (ownerPlayer.steam_name ~= "") and ownerPlayer.steam_name or owner
    printToColor(string.format(i18n.getStrById("INV_blocked_msg"), invName, ownerName), player.color, {1, 0.5, 0.1})
    return true
  end
  return false
end

local function refreshLeaderState(slot)
  local mat = matForSlot(slot)
  if not mat then return end

  local tokens = activationTokensOn(mat)
  for action = 1, ACTIONS_PER_INV do
    local token = tokens[action]
    local isLeader = (token ~= nil) and (token.memo == "Leader Activation Token")
    INV_STATE.isLeaderAction[slot][action] = isLeader
    self.UI.setAttribute(actionId(slot, action), "image", actionImage(isLeader, INV_STATE.actions[slot][action]))
  end
end

local function refreshAllLeaderStates()
  for slot = 1, MAX_INV do
    if TABLE_DATA.players[slot] then
      refreshLeaderState(slot)
    end
  end
end

local function syncActivationToken(slot, action, spent)
  local mat = matForSlot(slot)
  if not mat then
    print("[INV] syncToken: no mat for slot=" .. slot)
    return
  end

  local token = activationTokensOn(mat)[action]
  if not token then
    print("[INV] syncToken: no token at slot=" .. slot .. " action=" .. action)
    return
  end

  local isLeader = token.memo == "Leader Activation Token"
  if isLeader ~= INV_STATE.isLeaderAction[slot][action] then
    refreshAllLeaderStates()
  end

  if token.is_face_down ~= spent then
    token.flip()
  end
end

local function locateToken(token)
  for slot, player in ipairs(TABLE_DATA.players) do
    local mat = player.obj
    if mat then
      for action, t in ipairs(activationTokensOn(mat)) do
        if t == token then
          return slot, action
        end
      end
    end
  end
end

local function buildActionButton(p, a)
  return {
    tag = "Button",
    attributes = {
      id              = actionId(p, a),
      onClick         = "investigatorToggleAction",
      image           = actionImage(false, false),
      color           = "#FFFFFF",
      text            = "",
      minWidth        = ACTION_SIZE,
      preferredWidth  = ACTION_SIZE,
      flexibleWidth   = "0",
      minHeight       = ACTION_SIZE,
      preferredHeight = ACTION_SIZE,
    },
  }
end

local function buildAvatarButton(p)
  return {
    tag = "Button",
    attributes = {
      id              = "INV_avatar_" .. p,
      onClick         = "investigatorSeatPlayer",
      text            = "",
      image           = AVATAR_PLACEHOLDER,
      color           = "#FFFFFF",
      minWidth        = AVATAR_SIZE,
      preferredWidth  = AVATAR_SIZE,
      flexibleWidth   = "0",
      minHeight       = AVATAR_SIZE,
      preferredHeight = AVATAR_SIZE,
    },
    children = {
      {
        tag = "Panel",
        attributes = {
          id             = "INV_avatar_" .. p .. "_border",
          width          = BORDER_W,
          height         = AVATAR_SIZE,
          offsetXY       = "-3 0",
          rectAlignment  = "MiddleLeft",
          color          = slotBorderColor(p),
        },
      },
    },
  }
end

local function buildRow(p)
  return {
    tag = "HorizontalLayout",
    attributes = {
      id                    = "INV_row_" .. p,
      active                = (p <= DEFAULT_COUNT) and "true" or "false",
      minHeight             = ROW_H,
      preferredHeight       = ROW_H,
      flexibleHeight        = "0",
      padding               = "0",
      spacing               = "10",
      childAlignment        = "MiddleLeft",
      childForceExpandWidth = "false",
      childForceExpandHeight = "false",
    },
    children = {
      buildAvatarButton(p),
      { tag = "Text", attributes = { id = "INV_name_" .. p .. "_text", text = defaultInvestigatorName(p), color = TEXT_COL, font = FONT, fontSize = "22", alignment = "MiddleLeft", flexibleWidth = "1" } },
      {
        tag = "HorizontalLayout",
        attributes = {
          id                     = "INV_actions_" .. p,
          spacing                = "10",
          childForceExpandWidth  = "false",
          childForceExpandHeight = "false",
          flexibleWidth          = "0",
        },
        children = { buildActionButton(p, 1), buildActionButton(p, 2) },
      },
      {
        tag = "Button",
        attributes = {
          id              = "INV_encounter_" .. p,
          onClick         = "investigatorEncounterClick",
          active          = "false",
          text            = i18n.getStrById("INV_encounter"),
          image           = "phase_button_3",
          color           = "#FFFFFF",
          textColor       = TEXT_COL,
          font            = FONT,
          fontSize        = "18",
          minWidth        = PHASE_BTN_W,
          preferredWidth  = PHASE_BTN_W,
          flexibleWidth   = "0",
          minHeight       = ACTION_SIZE,
          preferredHeight = ACTION_SIZE,
        },
      },
      {
        tag = "Button",
        attributes = {
          id              = "INV_mythos_" .. p,
          onClick         = "investigatorMythosClick",
          active          = "false",
          text            = mythosCountText(2),
          image           = "phase_button_4",
          color           = "#FFFFFF",
          textColor       = TEXT_COL,
          font            = FONT,
          fontSize        = "18",
          minWidth        = PHASE_BTN_W,
          preferredWidth  = PHASE_BTN_W,
          flexibleWidth   = "0",
          minHeight       = ACTION_SIZE,
          preferredHeight = ACTION_SIZE,
        },
      },
    },
  }
end

local function buildRows()
  local rows = {}
  for p = 1, MAX_INV do
    table.insert(rows, buildRow(p))
  end
  return rows
end

local function buildBody()
  return {
    tag = "VerticalLayout",
    attributes = {
      id                     = "INV_body",
      padding                = "2 " .. PAD .. " " .. PAD .. " " .. PAD,
      spacing                = SECTION_SPACING,
      flexibleWidth          = "1",
      childForceExpandWidth  = "true",
      childForceExpandHeight = "false",
    },
    children = {
      {
        tag = "VerticalLayout",
        attributes = {
          id                     = "INV_list",
          spacing                = ROW_SPACING,
          childForceExpandWidth  = "true",
          childForceExpandHeight = "false",
        },
        children = buildRows(),
      },
      {
        tag = "Button",
        attributes = {
          id              = "INV_apply_text",
          onClick         = "investigatorApplyAll",
          visibility      = "Host",
          text            = i18n.getStrById("INV_apply_text"),
          color           = "clear",
          textColor       = INV_GOLD,
          font            = FONT,
          fontSize        = "16",
          minHeight       = APPLY_H,
          preferredHeight = APPLY_H,
          flexibleHeight  = "0",
        },
      },
    },
  }
end

