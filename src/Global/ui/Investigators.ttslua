end

function investigatorToggleAction(player, alt, id)
  local p, a = id:match("INV_action_(%d+)_(%d+)")
  p, a = tonumber(p), tonumber(a)
  if not p or not a then
    print("[INV] toggle: bad id=" .. tostring(id))
    return
  end

  if blockedByOwner(p, player) then return end

  INV_STATE.actions[p][a] = not INV_STATE.actions[p][a]
  refreshActionButton(p, a)
  syncActivationToken(p, a, INV_STATE.actions[p][a])
  saveActionsToGameData()
end

function onActivationTokenFlipped(token)
  local slot, action = locateToken(token)
  if not slot then return end
  local spent = token.is_face_down
  if INV_STATE.actions[slot][action] ~= spent then
    INV_STATE.actions[slot][action] = spent
    refreshActionButton(slot, action)
  end
end

function investigatorApplyAll(player, alt, id)
  if not player.host then return end
  if not INV_STATE.applied then
    INV_STATE.snapshot = {}
    for p = 1, INV_STATE.count do
      INV_STATE.snapshot[p] = {}
      for a = 1, ACTIONS_PER_INV do
        INV_STATE.snapshot[p][a] = INV_STATE.actions[p][a]
        INV_STATE.actions[p][a]  = true
        refreshActionButton(p, a)
        syncActivationToken(p, a, true)
      end
    end
    INV_STATE.applied = true
    setApplyPressed(true)
    saveActionsToGameData()
  else
    for p = 1, INV_STATE.count do
      for a = 1, ACTIONS_PER_INV do
        local prev = INV_STATE.snapshot and INV_STATE.snapshot[p] and INV_STATE.snapshot[p][a] or false
        INV_STATE.actions[p][a] = prev
        refreshActionButton(p, a)
        syncActivationToken(p, a, prev)
      end
    end
    INV_STATE.applied  = false
    INV_STATE.snapshot = nil
    setApplyPressed(false)
    saveActionsToGameData()
  end
end

function investigatorToggleCollapse()
  local isOpen = self.UI.getAttribute("investigators", "active") == "True"
  self.UI.setAttribute("investigators", "active", not isOpen)
  self.UI.setAttribute("INV_collapse_alone", "active", isOpen)
end

function setInvestigatorPhase(phase)
  INV_STATE.phase = phase
  local isAction    = (phase == 1)
  local isEncounter = (phase == 3)
  local isMythos    = (phase == 4)

  if isEncounter then
    for p = 1, INV_STATE.count do INV_STATE.encounterDone[p] = false end
  end
  if isMythos then
    for p = 1, INV_STATE.count do INV_STATE.mythosCount[p] = 2 end
    INV_STATE.mythosActive = nil
  end

  self.UI.setAttribute("INV_apply_text", "active", phase == 1)
  if isAction then
    setApplyPressed(INV_STATE.applied)
  end

  for p = 1, MAX_INV do
    local active = (p <= INV_STATE.count)
    self.UI.setAttribute("INV_actions_"   .. p, "active", isAction and active)

    local encShow = isEncounter and active and not INV_STATE.encounterDone[p]
    self.UI.setAttribute("INV_encounter_" .. p, "active", encShow)
    if encShow then
      self.UI.setAttribute("INV_encounter_" .. p, "textColor", TEXT_COL)
    end

    local mythShow = isMythos and active
    self.UI.setAttribute("INV_mythos_" .. p, "active", mythShow)
    if mythShow then
      self.UI.setAttribute("INV_mythos_" .. p, "text",      mythosCountText(INV_STATE.mythosCount[p]))
      self.UI.setAttribute("INV_mythos_" .. p, "textColor", TEXT_COL)
    end
  end
end

local function markEncounterDone(p)
  INV_STATE.encounterDone[p] = true
  gameData.encounterDone = gameData.encounterDone or {}
  gameData.encounterDone[p] = true
  self.UI.setAttribute("INV_encounter_" .. p, "active", false)
end

local function consumeMythosCount(p)
  if isDrawMythInProcess then
    local msg = i18n.getStrById("LOG_myth_in_process")
    if currentMythAction then msg = msg .. ": " .. currentMythAction end
    broadcastToAll(msg, "Orange")
    return false
  end

  if gameData.phase ~= 4 then return true end

  if INV_STATE.mythosActive ~= nil and (INV_STATE.mythosCount[INV_STATE.mythosActive] or 0) <= 0 then
    INV_STATE.mythosActive = nil
    gameData.mythosActive  = nil
  end

  if INV_STATE.mythosActive ~= nil and INV_STATE.mythosActive ~= p then
    local activeSlot = INV_STATE.mythosActive
    local activeName = INV_STATE.nameBySlot[activeSlot] or defaultInvestigatorName(activeSlot)
    broadcastToAll(string.format(i18n.getStrById("INV_mythos_blocked"), activeName, INV_STATE.mythosCount[activeSlot]), "Orange")
    return false
  end

  local count = INV_STATE.mythosCount[p]
  if count <= 0 then return true end
  count = count - 1
  INV_STATE.mythosCount[p] = count
  INV_STATE.mythosActive = (count == 0) and nil or p
  self.UI.setAttribute("INV_mythos_" .. p, "text",      mythosCountText(count))
  self.UI.setAttribute("INV_mythos_" .. p, "textColor", TEXT_COL)
  gameData.mythosCount = gameData.mythosCount or {}
  gameData.mythosCount[p] = INV_STATE.mythosCount[p]
  gameData.mythosActive   = INV_STATE.mythosActive
  return true
end

function refreshInvestigatorStaticText()
  local text = i18n.getStrById("INV_encounter")
  for p = 1, MAX_INV do
    self.UI.setAttribute("INV_encounter_" .. p, "text", text)
  end
end

function investigatorEncounterClick(player, alt, id)
  local p = tonumber(id:match("INV_encounter_(%d+)"))
  if not p then return end

  if blockedByOwner(p, player) then return end

  markEncounterDone(p)
  onClickEncounter(nil, player.color)
end

function investigatorMythosClick(player, alt, id)
  local p = tonumber(id:match("INV_mythos_(%d+)"))
  if not p then return end

  if blockedByOwner(p, player) then return end

  if not consumeMythosCount(p) then return end
  onClickDrawMythos(nil, player.color)
end

function syncEncounterDoneForColor(color)
  local p = slotForColor(color)
  if p then markEncounterDone(p) end
end

function syncMythosCountForColor(color)
  local p = slotForColor(color)
  if not p then return true end
  return consumeMythosCount(p)
end

function investigatorSeatPlayer(player, alt, id)
  local p = tonumber(id:match("INV_avatar_(%d+)"))
  if not p then return end

  local hand = getHandForSlot(p)
  if not hand then return end

  local targetColor = hand.getValue()
  if not targetColor or targetColor == "" then return end
  local occupant = Player[targetColor]
  if occupant and occupant.seated and occupant.steam_id ~= player.steam_id then return end
  player.changeColor(targetColor)

  local mat = TABLE_DATA.players[p] and TABLE_DATA.players[p].obj
  if mat then
    local pos = mat.getPosition()
    Wait.frames(function()
      local p2 = Player[targetColor]
      if p2 and p2.seated then
        p2.lookAt({position = pos, pitch = 65, yaw = 0, distance = 30})
      end
    end, 3)
  end
end

function getInvestigatorNameForMatGuid(guid)
  for slot, player in ipairs(TABLE_DATA.players) do
    if player.guid == guid then
      return INV_STATE.nameBySlot[slot]
    end
  end
end

function getInvestigatorMatByColor(color)
  for slot = 1, MAX_INV do
    if TABLE_DATA.players[slot] then
      local hand = getHandForSlot(slot)
      if hand and hand.getValue() == color then
        return TABLE_DATA.players[slot].obj
      end
    end
  end
end

function setInvestigatorName(name, mat, baseKey)
  if not name or name == "" then return end

  local slot = INV_STATE.slotByName[name]

  if not slot and mat then
    local guid = mat.getGUID()
    for i, player in ipairs(TABLE_DATA.players) do
      if player.guid == guid then
        slot = i
        break
      end
    end
    if slot then
      local oldName = INV_STATE.nameBySlot[slot]
      if oldName then INV_STATE.slotByName[oldName] = nil end
    end
  end

  if not slot then return end

  INV_STATE.slotByName[name] = slot
  INV_STATE.nameBySlot[slot] = name
  INV_STATE.baseKeyBySlot[slot] = baseKey

  refreshLeaderState(slot)
  self.UI.setAttribute("INV_name_" .. slot .. "_text", "text", shortDisplayName(name, baseKey))
  if baseKey then
    self.UI.setAttribute("INV_avatar_" .. slot, "image", baseKey .. "_portrait")
  end
  refreshPanelWidth()
end

function clearInvestigatorSlot(mat)
  if not mat then return end
  local guid = mat.getGUID()
  local slot = nil
  for i, player in ipairs(TABLE_DATA.players) do
    if player.guid == guid then slot = i break end
  end
  if not slot then return end

  local name = INV_STATE.nameBySlot[slot]
  if name then INV_STATE.slotByName[name] = nil end
  INV_STATE.nameBySlot[slot]     = nil
  INV_STATE.baseKeyBySlot[slot]  = nil
  INV_STATE.isLeaderAction[slot] = {}
  for a = 1, ACTIONS_PER_INV do
    INV_STATE.actions[slot][a]        = false
    INV_STATE.isLeaderAction[slot][a] = false
    refreshActionButton(slot, a)
  end
  self.UI.setAttribute("INV_name_" .. slot .. "_text", "text", defaultInvestigatorName(slot))
  self.UI.setAttribute("INV_avatar_" .. slot, "image", AVATAR_PLACEHOLDER)
  refreshPanelWidth()
end

function restoreInvestigatorSessionState()
  if gameData.invActions then
    for pStr, actions in pairs(gameData.invActions) do
      local pNum = tonumber(pStr)
      if pNum and INV_STATE.actions[pNum] then
        for aStr, spent in pairs(actions) do
          local aNum = tonumber(aStr)
          if aNum then
            INV_STATE.actions[pNum][aNum] = spent
            refreshActionButton(pNum, aNum)
          end
        end
      end
    end
  end
  if gameData.invApplied then
    INV_STATE.applied = gameData.invApplied
    setApplyPressed(INV_STATE.applied)
  end

  if INV_STATE.phase == 3 and gameData.encounterDone then
    for pStr, done in pairs(gameData.encounterDone) do
      local pNum = tonumber(pStr)
      if done and pNum then
        INV_STATE.encounterDone[pNum] = true
        self.UI.setAttribute("INV_encounter_" .. pNum, "active", false)
      end
    end
  end

  if INV_STATE.phase == 4 and gameData.mythosCount then
    for pStr, count in pairs(gameData.mythosCount) do
      local pNum = tonumber(pStr)
      if pNum then
        INV_STATE.mythosCount[pNum] = count
        local show = pNum <= INV_STATE.count
        self.UI.setAttribute("INV_mythos_" .. pNum, "active", show)
        if show then
          self.UI.setAttribute("INV_mythos_" .. pNum, "text", mythosCountText(count))
        end
      end
    end
    INV_STATE.mythosActive = gameData.mythosActive and tonumber(gameData.mythosActive)
  end
end

function getUnfinishedInvestigatorNames()
  local names = {}
  for p = 1, INV_STATE.count do
    local hasFree = false
    for a = 1, ACTIONS_PER_INV do
      if not INV_STATE.actions[p][a] then
        hasFree = true
        break
      end
    end
    if hasFree then
      names[#names + 1] = INV_STATE.nameBySlot[p] or defaultInvestigatorName(p)
    end
  end
  return names
end

function resetAllActionsAndTokens()
  for p = 1, MAX_INV do
    for a = 1, ACTIONS_PER_INV do
      INV_STATE.actions[p][a] = false
      refreshActionButton(p, a)
      if p <= INV_STATE.count then
        syncActivationToken(p, a, false)
      end
    end
  end
  INV_STATE.applied  = false
  INV_STATE.snapshot = nil
  setApplyPressed(false)
  saveActionsToGameData()
end

function spendActionForDetainedFigure(displayName)
  local slot = INV_STATE.slotByName[displayName]
  if not slot then return false, nil, nil, false end
  for a = 1, ACTIONS_PER_INV do
    if not INV_STATE.actions[slot][a] then
      INV_STATE.actions[slot][a] = true
      refreshActionButton(slot, a)
      syncActivationToken(slot, a, true)
      saveActionsToGameData()
      return true, slot, a, false
    end
  end
  return false, slot, nil, true
end

function restoreActionForDetainedFigure(displayName)
  local slot = INV_STATE.slotByName[displayName]
  if not slot then return false end
  for a = ACTIONS_PER_INV, 1, -1 do
    if INV_STATE.actions[slot][a] then
      INV_STATE.actions[slot][a] = false
      refreshActionButton(slot, a)
      syncActivationToken(slot, a, false)
      saveActionsToGameData()
      return true
    end
  end
  return false
end

function setInvestigatorCount(n)
  n = tonumber(n) or MIN_INV
  if n < MIN_INV then n = MIN_INV elseif n > MAX_INV then n = MAX_INV end
  INV_STATE.count = n

  for p = 1, MAX_INV do
    self.UI.setAttribute("INV_row_" .. p, "active", p <= n)
  end

  for p = 1, MAX_INV do
    for a = 1, ACTIONS_PER_INV do
      INV_STATE.actions[p][a] = false
    end
  end
  INV_STATE.applied  = false
  INV_STATE.snapshot = nil
  refreshAllActionColors()
  setApplyPressed(false)

  INV_STATE.slotByName     = {}
  INV_STATE.nameBySlot     = {}
  INV_STATE.baseKeyBySlot  = {}
  INV_STATE.isLeaderAction = {}
  for p = 1, MAX_INV do
    INV_STATE.isLeaderAction[p] = {}
    INV_STATE.encounterDone[p]  = false
    INV_STATE.mythosCount[p]    = 2
    for a = 1, ACTIONS_PER_INV do
      INV_STATE.isLeaderAction[p][a] = false
    end
    self.UI.setAttribute("INV_name_"      .. p .. "_text", "text", defaultInvestigatorName(p))
    self.UI.setAttribute("INV_avatar_"    .. p, "image", AVATAR_PLACEHOLDER)
    self.UI.setAttribute("INV_actions_"   .. p, "active", p <= n)
    self.UI.setAttribute("INV_encounter_" .. p, "active", false)
    self.UI.setAttribute("INV_mythos_"    .. p, "active", false)
  end
  INV_STATE.phase        = 1
  INV_STATE.mythosActive = nil

  refreshPanelWidth()
  self.UI.setAttribute("INV_collapse_alone", "active", false)
  self.UI.setAttribute("investigators", "active", true)
end
