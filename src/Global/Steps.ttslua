  activatemarkersonlocations        = processStepActivateMarkersOnLocations,
  attachmarkertomonster             = processStepAttachMarkerToMonster,
  movemarkertoscenariosheet         = processStepMoveMarkerToScenarioSheet,
  movemarkertolocation              = processStepMoveMarkerToLocation,
  removeneighborhood                = processStepRemoveNeighborhood,
  removestreet                      = processStepRemoveStreet,
  removeblankmythostoken            = processStepRemoveBlankMythosToken,
  removedoomfromscenariosheet       = processStepRemoveDoomFromScenarioSheet,
