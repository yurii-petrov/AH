  removetoken          = processStepRemoveToken,
  takecard             = processStepTakeCard,
  cycletokenlayout     = processStepCycleTokenLayout,
  contextsetup         = processStepContextSetup,
  placescenariodecks   = processStepPlaceScenarioDecks,
  mergeeventdeck       = processStepMergeEventDeck,
  replaceeventdeck     = processStepReplaceEventDeck,
  takecodexfromarchive = processStepTakeCodexFromArchive,
  returncodextoarchive = processStepReturnCodexToArchive,
  returncodexbynumber  = processStepReturnCodexByNumber,
  returnbridge         = processStepReturnBridge,
  findmonsterbytype          = processStepFindMonsterByType,
  placetokensonlocations     = processStepPlaceTokensOnLocations,
  fliptokenonlocation               = processStepFlipTokenOnLocation,
  findandremovetokenonlocation      = processStepFindAndRemoveTokenOnLocation,
  addmythostoken                    = processStepAddMythosToken,
  clearmarkersonlocations           = processStepClearMarkersOnLocations,
  spawncardbelowcodex               = processStepSpawnCardBelowCodex,
  spawnmonsteronlocation            = processStepSpawnMonsterOnLocation,
  spawnmonsterfromdeck              = processStepSpawnMonsterFromDeck,
  seedcodexencounters               = processStepSeedCodexEncounters,
