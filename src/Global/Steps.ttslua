  spawnrandomsetasidemonsters       = processStepSpawnRandomSetasideMonsters,
  placerandomonencounterdeck        = processStepPlaceRandomOnEncounterDeck,
}

function processSteps(data)
  if not data.steps then
    log("No steps to process")
    return
  end

  local function runStep(i)
    if i > #data.steps then
      local ctx = data.context
      if ctx and ctx.removeAfterUse and ctx.codexMat then
        ctx.codexMat.call("onActionSuccess", ctx.removeAfterUse)
      end
      return
    end
    processStep(data.steps[i], data.context, function()
      runStep(i + 1)
    end)
  end

  runStep(1)
end

function processStep(step, context, onDone)
  if not step or not step.type then
    log("[processStep] step.type is nil")
    if onDone then onDone() end
    return
  end

  local stepType = string.lower(step.type)
  local handler = STEP_HANDLERS[stepType]

  if handler then
    handler(step, context, onDone)
  else
    log("[processStep] Unknown step type: " .. stepType)
    if onDone then onDone() end
  end
end
