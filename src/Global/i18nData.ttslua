  ["MM_scenario10_desc_text"] = {
    ["en"] = "An unearthly melody floats through the crisp autumn air, all but imperceptible to the waking mind. In dreams, you visit a fantastical undersea city and revel in the glory of something massive, just beyond your sight.",
    ["uk"] = "Неземна мелодія линe крізь прозоре осіннє повітря, майже непомітна для пробудженої свідомості. У снах ти відвідуєш фантастичне підводне місто й захоплено тішишся величчю чогось грандіозного — та прихованого за межею твого зору.",
  },
  ["MM_scenario10_name_text"] = {
    ["en"] = "DREAMS OF R'LYEH",
    ["uk"] = "Марення Р’льєху",
  },
  ["MM_scenario11_desc_text"] = {
    ["en"] = "A plague of unquiet spirits washes over Arkham, creating a psychic disturbance that cannot be ignored. Trapped by an ancient pact, these lost souls must be freed from the ancient evil that binds them for eternity.",
    ["uk"] = "Чума неприкаяних душ накриває Аркгем, породжуючи психічний розлад, який неможливо ігнорувати. Зв’язані древнім договором, ці загублені душі мають бути звільнені від зла, що тримає їх у вічному полоні.",
  },
  ["MM_scenario11_name_text"] = {
    ["en"] = "BOUND TO SERVE",
    ["uk"] = "Зв’язані Служити",
  },
  ["MM_scenario12_desc_text"] = {
    ["en"] = "Ancient magic has torn through the veil that protects Arkham from the worlds beyond. Terrible creatures erupt from the Underworld to threaten all that you hold dear.",
    ["uk"] = "Стародавня магія розірвала завісу, що захищала Аркгем від інших світів. Жахливі створіння вириваються з Підземного Cвіту, загрожуючи всьому, що тобі дороге.",
  },
  ["MM_scenario12_name_text"] = {
    ["en"] = "THE DEAD CRY OUT",
    ["uk"] = "Поклик Мертвих",
  },
  ["MM_scenario13_desc_text"] = {
    ["en"] = "For eons, Yog-Sothoth has observed the universe from beyond time and beyond space. Content no longer simply to watch and wait, the Lurker at the Threshold stirs. Countless thralls labor to open the gate that locks the Ancient One outside of our universe.",
    ["uk"] = "Протягом віків Йог-Сотот споглядав всесвіт з-за меж простору й часу. Але більше він не задовольняється спостереженням. Тінь за Порогом, прокидається. Безліч одержимих трудяться, щоб відчинити браму, яка стримує Прадавнього поза нашим всесвітом.",
  },
  ["MM_scenario13_name_text"] = {
    ["en"] = "THE KEY AND THE GATE",
    ["uk"] = "Ключ і Брама",
  },
  ["MM_scenario1_desc_text"] = {
    ["en"] = "At the center of infinity slumbers Azathoth, lulled to sleep by the ceaseless piping of accursed flutes. Yet some mortals would seek to draw the infinite power and calamity of the Blind Idiot God to them, and thereby doom all of humanity...",
    ["uk"] = "Азатот дрімає в центрі нескінченності, заколисаний безперервним співом проклятих флейт. Утім, деякі смертні шукають невичерпної сили й руйнувань, які принесе Сліпий божевільний бог, водночас прирікаючи усе людство на загибель...",
  },
  ["MM_scenario1_name_text"] = {
    ["en"] = "APPROACH OF AZATHOTH",
    ["uk"] = "Пришестя Азатота",
  },
  ["MM_scenario2_desc_text"] = {
    ["en"] = "The ghouls that dwell beneath the earth hunger for the flesh of corpses, yet even they live in worshipful fear of the Devourer Below. But the ghouls are not the only worshipers of Umôrdhoth in Arkham...",
    ["uk"] = "Гулі, що живуть під землею, вічно прагнуть плоті трупів, але навіть вони бояться Пожирача з Глибин. Однак гулі не єдині послідовники Умордота в Аркгемі...",
  },
  ["MM_scenario2_name_text"] = {
    ["en"] = "FEAST FOR UMÔRDHOTH",
    ["uk"] = "Трапеза Умордота",
  },
  ["MM_scenario3_desc_text"] = {
    ["en"] = "In the cold void between worlds, something lurks. Beyond the veil, it whispers, reaching out for those with the power to free it from its prison. Those who fall into its thrall gain great power, but at a terrible price. And each day, its freedom draws nearer.",
    ["uk"] = "Щось чигає в холодній порожнечі між світами. Ховаючись під покровом, воно шепоче до тих, хто здатен звільнити його з вʼязниці. Одержимі ним здобувають велику силу, але її ціна жахливо висока. І день за днем його свобода стає все ближчою.",
  },
  ["MM_scenario3_name_text"] = {
    ["en"] = "VEIL OF TWILIGHT",
    ["uk"] = "Покров\nСутінків",
  },
  ["MM_scenario4_desc_text"] = {
    ["en"] = "In his house at R'lyeh, dead Cthulbu waits dreaming. He slumbers and waits until the stars are right to bring R'lyeh back from its home beneath the waves and for the Great Old Ones to return. For that is not dead which can eternal lie, and with strange aeons even death may die.",
    ["uk"] = "У домі своєму, у Р'льєху, мертвий Ктулху чекає вві сні. Він дрімає і чекає, коли зірки стануть на свої місця і Р'льєх вирине з морських глибин, а Стародавні повернуться в цей світ. Бо не мертве те, що вічно пробуває, а з вічністю, бува, і смерть сама вмирає",
  },
  ["MM_scenario4_name_text"] = {
    ["en"] = "ECHOES OF THE DEEP",
    ["uk"] = "Відлуння\nБезодні",
  },
  ["MM_scenario5_desc_text"] = {
    ["en"] = "The gangs of Arkham have a long history, and the peace between the O'Bannions and the Sheldons has always been tenuous at best. In the sweltering summer of 1926, a dark shadow pushes them into savage conflict.",
    ["uk"] = "Банди Аркгему мають довгу історію, та мир між О'Бенніонами та Шелдонами був радше ілюзією, ніж реальністю. У задушливе літо 1926 року, темна тінь остаточно штовхає їх у дику, нещадну війну.",
  },
  ["MM_scenario5_name_text"] = {
    ["en"] = "SHOTS IN THE DARK",
    ["uk"] = "Постріли в Темряві",
  },
  ["MM_scenario6_desc_text"] = {
    ["en"] = "The Beast of Voormithadreth slumbers, while the followers he abandoned on distant Yuggoth prepare offerings of supplication for his ravenous appetite. Should the toad-like Sleeper of N'Kai awaken, doom shall come for us all.",
    ["uk"] = "Чудовисько з Вуормітхадрету ще спить. Але на далекому Юготі ті, кого він залишив, готують жертви, аби втамувати його жахливий голод. Та якщо жабоподібний Сплячий з Н’Каї прокинеться, світ зануриться в морок загибелі.",
  },
  ["MM_scenario6_name_text"] = {
    ["en"] = "SILENCE OF TSATHOGGUA",
    ["uk"] = "Мовчання Тсатгоґґуа",
  },
  ["MM_scenario7_desc_text"] = {
    ["en"] = "Deep beneath Devil Reef, the tyrants of Y'ha-nthlei rule the dark waves, yearning to surpass their ancient, mortal frames. They stir below the water, sending their Deep One progeny to corrupt the surface world.",
    ["uk"] = "Глибоко під Рифом Диявола Тирани з Й’а-нтлея правлять темними хвилями, прагнучи перевершити свої давні, смертні оболонки. Вони ворушаться під водою, посилаючи своїх нащадків — Глибоководних — щоб занапастити світ на поверхні.",
  },
  ["MM_scenario7_name_text"] = {
    ["en"] = "TYRANTS OF RUIN",
    ["uk"] = "Тирани Загибелі",
  },
  ["MM_scenario8_desc_text"] = {
    ["en"] = "In the mist-shrouded town of Kingsport, the elite prosper within a newly founded social group called the Lantern Club. In the alleys and gutters, people once reported missing reappear, bereft of their memories and mere shadows of their former selves.",
    ["uk"] = "У вкритому туманом Кінгспорті еліта процвітає в новоствореному товаристві під назвою Клуб Ліхтаря. Тим часом у провулках і канавках знову з’являються люди, колись зниклі безвісти, — без спогадів і лише як тіні самих себе.",
  },
  ["MM_scenario8_name_text"] = {
    ["en"] = "THE PALE LANTERN",
    ["uk"] = "Блідий Ліхтар",
  },
  ["MM_scenario9_desc_text"] = {
    ["en"] = "Ithaqua the Wind-Walker lurks in the frozen north. He is the cold wind that creeps into the soul, and the hungry ice that entombs the unwary. Forsaken and alone, Ithaqua spreads his influence in the cruel hope that he might beget a terrible progeny - a new scion that could overcome even the elder gods.",
    ["uk"] = "Ітаква, той, що блукає вітрами, у крижаній півночі. Він — холодний подих, що просочується в душу, і ненаситна крига, що ховає необачних у крижаній могилі. Забутий і самотній, Ітаква поширює свій вплив у жорстокій надії породити жахливе потомство — нового нащадка, здатного перевершити навіть  давніх богів.",
  },
  ["MM_scenario9_name_text"] = {
    ["en"] = "ITHAQUA'S CHILDREN",
    ["uk"] = "Діти Ітакви",
  },
