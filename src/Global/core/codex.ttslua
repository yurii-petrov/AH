
function findCodexAttachmentIndex(codexMat, attType)
  attType = attType or "codex"
  for _, att in ipairs(codexMat.getAttachments()) do
    local attData = parseJson(att.memo)
    if attData and attData.type and iEquals(attData.type, attType) then
      return att.index
    end
  end
end

function removeCodexAttachment(codexMat)
  local index = findCodexAttachmentIndex(codexMat)
  if not index then return nil end
  return codexMat.removeAttachment(index)
end

function detachCardAndDestructMat(codexMat, attType)
  local index = findCodexAttachmentIndex(codexMat, attType)
  if not index then return nil end

  local card = codexMat.removeAttachment(index)
  if not card then return nil end

  card.interactable = true
  codexMat.destruct()
  return card
end

function returnCodexMatToArchive(codexMat, archive)
  local index = findCodexAttachmentIndex(codexMat)
  if not index then return false end

  local codexCard = codexMat.removeAttachment(index)
  if not codexCard then return false end

  codexCard.interactable = true
  codexCard.setRotation({0, 180, 180})
  archive.putObject(codexCard)
  codexMat.destruct()
  return true
end

function findCodexMatByNumber(locationMat, number)
  for _, snp in ipairs(locationMat.getSnapPoints()) do
    if snp.tags then
      for _, tag in ipairs(snp.tags) do
        if tag == "codex_mat" then
          local worldPos = locationMat.positionToWorld(snp.position)
          local objs = upCast_pos(worldPos, 1)
          for _, o in ipairs(objs) do
            if o.type == "Tile" then
              for _, att in ipairs(o.getAttachments()) do
                local data = parseJson(att.memo)
                if data and string.lower(tostring(data.type or "")) == "codex" and data.number == number then
                  return o
                end
              end
            end
          end
        end
      end
    end
  end
end

function findAllCodexMats(locationMat)
  local found = {}
  for _, snp in ipairs(locationMat.getSnapPoints()) do
    if snp.tags then
      for _, tag in ipairs(snp.tags) do
        if tag == "codex_mat" then
          local worldPos = locationMat.positionToWorld(snp.position)
          local objs = upCast_pos(worldPos, 1)
          for _, o in ipairs(objs) do
            if o.type == "Tile" then
              for _, att in ipairs(o.getAttachments()) do
                local data = parseJson(att.memo)
                if data and string.lower(tostring(data.type or "")) == "codex" and data.number then
                  table.insert(found, { mat = o, number = data.number })
                  break
                end
              end
            end
          end
        end
      end
    end
  end
  return found
end

function attachCardUnderCodexMat(codexMat, card, rotation)
  local CARD_OFFSET = 0.11
  local height      = codexMat.getBounds().size.y
  local matPos      = codexMat.getPosition()
  local existing    = #codexMat.getAttachments()

  card.setRotation(rotation)
  card.setPosition({
    x = matPos.x,
    y = matPos.y - height - CARD_OFFSET - existing * 0.05,
    z = matPos.z
  })
  card.interactable = false
  codexMat.addAttachment(card)
end

function placeMatUnderCodexMat(targetMat, hiddenMat, rotation)
  local GAP    = 0.05
  local height = targetMat.getBounds().size.y
  local matPos = targetMat.getPosition()

  local stacked = 0
  for _, o in ipairs(downCast_pos(matPos, 5)) do
    if o.getGUID() ~= targetMat.getGUID() and o.type == "Tile" then
      stacked = stacked + 1
    end
  end

  hiddenMat.setRotation(rotation)
  hiddenMat.setPosition({
    x = matPos.x,
    y = matPos.y - (height + GAP) * (stacked + 1),
    z = matPos.z
  })
  hiddenMat.interactable = false
  hiddenMat.setLock(true)
end
