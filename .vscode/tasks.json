{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Arkham Horror: Build",
      "type": "shell",
      "windows": {
        "command": "cmd",
        "args": [
          "/c",
          "py \"${workspaceFolder}\\locales\\_sync_po_files.py\" && py \"${workspaceFolder}\\locales\\_po_to_lua_converter.py\" && go run main.go --moddir=\"${workspaceFolder}\" --modfile=\"${env:USERPROFILE}\\Documents\\My Games\\Tabletop Simulator\\Saves\\ArkhamHorror.json\""
        ]
      },
      "osx": {
        "command": "\"${workspaceFolder}/.venv/bin/python\" \"${workspaceFolder}/locales/_sync_po_files.py\" && \"${workspaceFolder}/.venv/bin/python\" \"${workspaceFolder}/locales/_po_to_lua_converter.py\" && go run main.go -moddir \"${workspaceFolder}\" -modfile \"${userHome}/Library/Tabletop Simulator/Saves/ArkhamHorror.json\""
      },
      "options": {
        "cwd": "${workspaceFolder}${pathSeparator}..${pathSeparator}TTSModManager"
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },

    {
      "label": "Arkham Horror: Decompose",
      "type": "shell",
      "command": "go",
      "windows": {
        "args": [
          "run",
          "main.go",
          "--moddir=${workspaceFolder}",
          "--modfile=${env:USERPROFILE}\\Documents\\My Games\\Tabletop Simulator\\Saves\\ArkhamHorror.json",
          "--reverse"
        ]
      },
      "osx": {
        "args": [
          "run",
          "main.go",
          "-moddir",
          "${workspaceFolder}",
          "-modfile",
          "${userHome}/Library/Tabletop Simulator/Saves/ArkhamHorror.json",
          "-reverse"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}${pathSeparator}..${pathSeparator}TTSModManager"
      },
      "problemMatcher": []
    },

    {
      "label": "Arkham Horror: Sync Lua → JSON",
      "type": "shell",

      "windows": {
        "command": "py",
        "args": [
          "${workspaceFolder}\\src\\ConvertMemo\\sync_lua_to_json.py"
        ]
      },

      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": [
          "${workspaceFolder}/src/ConvertMemo/sync_lua_to_json.py"
        ]
      },

      "options": {
        "cwd": "${workspaceFolder}/src/ConvertMemo"
      },

      "problemMatcher": []
    },

    {
      "label": "Arkham Horror: Parse Memo",
      "type": "shell",

      "windows": {
        "command": "py",
        "args": [
          "${workspaceFolder}\\src\\ConvertMemo\\parse.py"
        ]
      },

      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": [
          "${workspaceFolder}/src/ConvertMemo/parse.py"
        ]
      },

      "options": {
        "cwd": "${workspaceFolder}/src/ConvertMemo"
      },

      "problemMatcher": []
    }
  ]
}