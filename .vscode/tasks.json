{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Arkham Horror: Build",
      "dependsOn": ["_index_assets", "_add_download_links", "_prepare_project"],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },

    {
      "label": "_prepare_project",
      "dependsOn": ["_sync_po", "_convert_po", "_go_build", "_go_build_done"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },

    {
      "label": "_sync_po",
      "type": "shell",
      "windows": {
        "command": "py",
        "args": ["${workspaceFolder}\\locales\\_sync_po_files.py"]
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["${workspaceFolder}/locales/_sync_po_files.py"]
      },
      "problemMatcher": []
    },

    {
      "label": "_convert_po",
      "type": "shell",
      "windows": {
        "command": "py",
        "args": ["${workspaceFolder}\\locales\\_po_to_lua_converter.py"]
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["${workspaceFolder}/locales/_po_to_lua_converter.py"]
      },
      "problemMatcher": []
    },

    {
      "label": "_go_build",
      "type": "shell",
      "command": "go",
      "windows": {
        "args": [
          "run",
          "main.go",
          "--moddir=${workspaceFolder}",
          "--modfile=${env:USERPROFILE}\\Documents\\My Games\\Tabletop Simulator\\Saves\\ArkhamHorror.json"
        ]
      },
      "osx": {
        "args": [
          "run",
          "main.go",
          "-moddir",
          "${workspaceFolder}",
          "-modfile",
          "${userHome}/Library/Tabletop Simulator/Saves/ArkhamHorror.json"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}${pathSeparator}..${pathSeparator}TTSModManager"
      },
      "problemMatcher": []
    },

    {
      "label": "_go_build_done",
      "type": "shell",
      "windows": {
        "command": "py",
        "args": ["${workspaceFolder}\\src\\tools\\box_echo.py", "MOD BUILD SUCCESS"]
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["${workspaceFolder}/src/tools/box_echo.py", "MOD BUILD SUCCESS"]
      },
      "problemMatcher": []
    },

    {
      "label": "Arkham Horror: Decompose",
      "dependsOn": ["_clean_objects", "_decompose", "_index_assets", "_add_download_links", "_check_uploads", "_decompose_done"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },

    {
      "label": "_check_uploads",
      "type": "shell",
      "windows": {
        "command": "py",
        "args": ["${workspaceFolder}\\src\\tools\\drive_upload.py"]
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["${workspaceFolder}/src/tools/drive_upload.py"]
      },
      "problemMatcher": []
    },

    {
      "label": "_decompose_done",
      "type": "shell",
      "windows": {
        "command": "py",
        "args": ["${workspaceFolder}\\src\\tools\\box_echo.py", "DECOMPOSE SUCCESS"]
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["${workspaceFolder}/src/tools/box_echo.py", "DECOMPOSE SUCCESS"]
      },
      "problemMatcher": []
    },

    {
      "label": "_clean_objects",
      "type": "shell",
      "windows": {
        "command": "powershell",
        "args": [
          "-Command",
          "Remove-Item -Recurse -Force '${workspaceFolder}\\objects' -ErrorAction SilentlyContinue"
        ]
      },
      "osx": {
        "command": "rm",
        "args": ["-rf", "${workspaceFolder}/objects"]
      },
      "problemMatcher": []
    },

    {
      "label": "_decompose",
      "type": "shell",
      "command": "go",
      "windows": {
        "args": [
          "run",
          "main.go",
          "--moddir=${workspaceFolder}",
          "--modfile=${env:USERPROFILE}\\Documents\\My Games\\Tabletop Simulator\\Saves\\ArkhamHorror.json",
          "--reverse"
        ]
      },
      "osx": {
        "args": [
          "run",
          "main.go",
          "-moddir",
          "${workspaceFolder}",
          "-modfile",
          "${userHome}/Library/Tabletop Simulator/Saves/ArkhamHorror.json",
          "-reverse"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}${pathSeparator}..${pathSeparator}TTSModManager"
      },
      "problemMatcher": []
    },

    {
      "label": "_index_assets",
      "type": "shell",
      "windows": {
        "command": "py",
        "args": ["${workspaceFolder}\\src\\tools\\asset_index_builder.py"]
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["${workspaceFolder}/src/tools/asset_index_builder.py"]
      },
      "problemMatcher": []
    },

    {
      "label": "_add_download_links",
      "type": "shell",
      "windows": {
        "command": "py",
        "args": ["${workspaceFolder}\\src\\tools\\add_download_links.py"]
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["${workspaceFolder}/src/tools/add_download_links.py"]
      },
      "problemMatcher": []
    },

    {
      "label": "Arkham Horror: Sync Lua → JSON",
      "type": "shell",
      "windows": {
        "command": "py",
        "args": ["${workspaceFolder}\\src\\ConvertMemo\\sync_lua_to_json.py"]
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["${workspaceFolder}/src/ConvertMemo/sync_lua_to_json.py"]
      },
      "options": {
        "cwd": "${workspaceFolder}/src/ConvertMemo"
      },
      "problemMatcher": []
    },

    {
      "label": "Arkham Horror: Replace EN Images",
      "type": "shell",
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["${workspaceFolder}/src/tools/replace_en_images.py", "${input:replaceEnTargetDir}", "--apply"]
      },
      "windows": {
        "command": "py",
        "args": ["${workspaceFolder}\\src\\tools\\replace_en_images.py", "${input:replaceEnTargetDir}", "--apply"]
      },
      "problemMatcher": []
    },

    {
      "label": "Arkham Horror: Parse Memo",
      "type": "shell",
      "windows": {
        "command": "py",
        "args": ["${workspaceFolder}\\src\\ConvertMemo\\parse.py"]
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["${workspaceFolder}/src/ConvertMemo/parse.py"]
      },
      "options": {
        "cwd": "${workspaceFolder}/src/ConvertMemo"
      },
      "problemMatcher": []
    },

    {
      "label": "Arkham Horror: Use Local Assets",
      "dependsOn": ["_use_local_assets", "_prepare_project"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },

    {
      "label": "_use_local_assets",
      "type": "shell",
      "windows": {
        "command": "py",
        "args": ["${workspaceFolder}\\src\\tools\\apply_asset_source.py", "--local", "--apply"]
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["${workspaceFolder}/src/tools/apply_asset_source.py", "--local", "--apply"]
      },
      "problemMatcher": []
    },

    {
      "label": "Arkham Horror: Use Google Drive Links",
      "dependsOn": ["_use_drive_links", "_prepare_project"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },

    {
      "label": "_use_drive_links",
      "type": "shell",
      "windows": {
        "command": "py",
        "args": ["${workspaceFolder}\\src\\tools\\apply_asset_source.py", "--drive", "--apply"]
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["${workspaceFolder}/src/tools/apply_asset_source.py", "--drive", "--apply"]
      },
      "problemMatcher": []
    },

    {
      "label": "Arkham Horror: Use Steam Cloud Links",
      "dependsOn": ["_use_steam_links", "_prepare_project"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },

    {
      "label": "_use_steam_links",
      "type": "shell",
      "windows": {
        "command": "py",
        "args": ["${workspaceFolder}\\src\\tools\\apply_asset_source.py", "--steam", "--apply"]
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["${workspaceFolder}/src/tools/apply_asset_source.py", "--steam", "--apply"]
      },
      "problemMatcher": []
    },

    {
      "label": "Arkham Horror: Upload New Assets to Drive",
      "dependsOn": ["_index_assets", "_upload_to_drive", "_use_drive_links", "_prepare_project"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },

    {
      "label": "_upload_to_drive",
      "type": "shell",
      "windows": {
        "command": "py",
        "args": ["${workspaceFolder}\\src\\tools\\drive_upload.py", "--apply"]
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["${workspaceFolder}/src/tools/drive_upload.py", "--apply"]
      },
      "problemMatcher": []
    },

    {
      "label": "Arkham Horror: Check Missing Drive Links",
      "dependsOn": ["_check_uploads"],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "replaceEnTargetDir",
      "type": "promptString",
      "description": "Target objects/ folder (relative to repo root) to swap /uk/ asset paths to /en/",
      "default": "objects/Enbag.a24119"
    }
  ]
}
