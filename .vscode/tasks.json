{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Arkham Horror: Build",
      "dependsOn": ["_go_build"],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },

    {
      "label": "Arkham Horror: Sync Translations",
      "type": "shell",
      "windows": {
        "command": "py",
        "args": ["${workspaceFolder}\\.vscode\\locales\\sync_translations.py"]
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["${workspaceFolder}/.vscode/locales/sync_translations.py"]
      },
      "options": {
        "cwd": "${workspaceFolder}${pathSeparator}.vscode"
      },
      "problemMatcher": []
    },

    {
      "label": "_go_build",
      "type": "shell",
      "windows": {
        "command": "py",
        "args": ["${workspaceFolder}\\.vscode\\build.py", "--action", "build", "--moddir", "${workspaceFolder}"]
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["${workspaceFolder}/.vscode/build.py", "--action", "build", "--moddir", "${workspaceFolder}"]
      },
      "options": {
        "cwd": "${workspaceFolder}${pathSeparator}.vscode"
      },
      "problemMatcher": []
    },

    {
      "label": "Arkham Horror: Decompose",
      "dependsOn": ["_decompose"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },

    {
      "label": "_decompose",
      "type": "shell",
      "windows": {
        "command": "py",
        "args": ["${workspaceFolder}\\.vscode\\build.py", "--action", "decompose", "--moddir", "${workspaceFolder}"]
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["${workspaceFolder}/.vscode/build.py", "--action", "decompose", "--moddir", "${workspaceFolder}"]
      },
      "options": {
        "cwd": "${workspaceFolder}${pathSeparator}.vscode"
      },
      "problemMatcher": []
    },

    {
      "label": "Arkham Horror: Sync Lua → JSON",
      "type": "shell",
      "windows": {
        "command": "py",
        "args": ["${workspaceFolder}\\src\\ConvertMemo\\sync_lua_to_json.py"]
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["${workspaceFolder}/src/ConvertMemo/sync_lua_to_json.py"]
      },
      "options": {
        "cwd": "${workspaceFolder}/src/ConvertMemo"
      },
      "problemMatcher": []
    },

    {
      "label": "Arkham Horror: Replace EN Images",
      "type": "shell",
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["${workspaceFolder}/src/tools/replace_en_images.py", "${input:replaceEnTargetDir}", "--apply"]
      },
      "windows": {
        "command": "py",
        "args": ["${workspaceFolder}\\src\\tools\\replace_en_images.py", "${input:replaceEnTargetDir}", "--apply"]
      },
      "problemMatcher": []
    },

    {
      "label": "Arkham Horror: Parse Memo",
      "type": "shell",
      "windows": {
        "command": "py",
        "args": ["${workspaceFolder}\\src\\ConvertMemo\\parse.py"]
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["${workspaceFolder}/src/ConvertMemo/parse.py"]
      },
      "options": {
        "cwd": "${workspaceFolder}/src/ConvertMemo"
      },
      "problemMatcher": []
    },

    {
      "label": "Arkham Horror: Sync Assets to Drive",
      "type": "shell",
      "windows": {
        "command": "py",
        "args": ["${workspaceFolder}\\.vscode\\sync_assets_to_drive.py"]
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["${workspaceFolder}/.vscode/sync_assets_to_drive.py"]
      },
      "options": {
        "cwd": "${workspaceFolder}${pathSeparator}.vscode"
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "replaceEnTargetDir",
      "type": "promptString",
      "description": "Target objects/ folder (relative to repo root) to swap /uk/ asset paths to /en/",
      "default": "objects/Enbag.a24119"
    }
  ]
}
