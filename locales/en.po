								"\n• 2 spell cards"
								"\n• 18 special cards"
								"\n• 12 starting cards"
								"\n• 6 condition cards"
								"\n• 20 monster cards" 

msgid "MM_addonSummary4_text"
msgstr "• 4 variations for base investigators"

